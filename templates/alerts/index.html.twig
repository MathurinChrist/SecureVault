{% extends 'base.html.twig' %}

{% block title %}Alertes de Sécurité - SecureVault{% endblock %}

{% block body_connected %}
<!-- Header -->
<div class="mb-6">
    <div class="flex items-start justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Alertes de Sécurité</h1>
            <p class="text-gray-500 mt-1 text-sm">Restez informé des menaces potentielles sur votre coffre-fort.</p>
        </div>
        {% if alerts|filter(a => not a.isRead)|length > 0 %}
        <form method="post" action="{{ path('app_alerts_mark_all_read') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('alert_action') }}">
            <button type="submit" class="flex items-center space-x-2 px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>Tout marquer comme lu</span>
            </button>
        </form>
        {% endif %}
    </div>
</div>

<!-- Stat cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-5 border-l-4 border-l-red-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-500 text-sm font-medium">Critique</p>
                <p class="text-3xl font-bold mt-1 text-red-500">{{ alerts|filter(a => a.type == 'danger')|length }}</p>
            </div>
            <div class="h-12 w-12 rounded-xl bg-red-50 flex items-center justify-center text-red-500">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
        </div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5 border-l-4 border-l-amber-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-500 text-sm font-medium">Avertissements</p>
                <p class="text-3xl font-bold mt-1 text-amber-500">{{ alerts|filter(a => a.type == 'warning')|length }}</p>
            </div>
            <div class="h-12 w-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-500">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
        </div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5 border-l-4 border-l-brand">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-500 text-sm font-medium">Informations</p>
                <p class="text-3xl font-bold mt-1 text-brand-mid">{{ alerts|filter(a => a.type == 'info')|length }}</p>
            </div>
            <div class="h-12 w-12 rounded-xl bg-brand/10 flex items-center justify-center text-brand-mid">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
        </div>
    </div>
</div>

<!-- Alert list -->
<div class="space-y-3">
    {% for alert in alerts %}
    <div class="bg-white rounded-xl border border-gray-200 hover:shadow-sm transition group {{ alert.isRead ? 'opacity-60' : '' }}">
        <div class="p-5 flex items-start space-x-4">
            <div class="mt-0.5 shrink-0">
                {% if alert.type == 'danger' %}
                <div class="h-10 w-10 rounded-xl bg-red-50 flex items-center justify-center text-red-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                {% elseif alert.type == 'warning' %}
                <div class="h-10 w-10 rounded-xl bg-amber-50 flex items-center justify-center text-amber-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                {% else %}
                <div class="h-10 w-10 rounded-xl bg-brand/10 flex items-center justify-center text-brand-mid">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                {% endif %}
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-1">
                    <h3 class="font-bold text-gray-900 flex items-center gap-2">
                        {{ alert.title }}
                        {% if not alert.isRead %}
                        <span class="h-2 w-2 rounded-full bg-brand shrink-0"></span>
                        {% endif %}
                    </h3>
                    <span class="text-xs text-gray-400 shrink-0 ml-4">{{ alert.createdAt|date('d M Y, H:i') }}</span>
                </div>
                <p class="text-sm text-gray-500">{{ alert.description }}</p>
                <div class="mt-3 flex items-center justify-between">
                    <span class="px-2 py-0.5 rounded-md bg-gray-100 text-[10px] font-bold uppercase tracking-wider text-gray-500 border border-gray-200">
                        {{ alert.category }}
                    </span>
                    <div class="flex items-center space-x-4 opacity-0 group-hover:opacity-100 transition-opacity">
                        {% if not alert.isRead %}
                        <form method="post" action="{{ path('app_alerts_mark_read', {id: alert.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('alert_action') }}">
                            <button type="submit" class="text-xs font-semibold text-brand-mid hover:text-brand uppercase tracking-wide">Marquer comme lu</button>
                        </form>
                        {% endif %}
                        <form method="post" action="{{ path('app_alerts_dismiss', {id: alert.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('alert_action') }}">
                            <button type="submit" class="text-xs font-semibold text-gray-400 hover:text-red-500 uppercase tracking-wide">Ignorer</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="text-center py-20 bg-white rounded-xl border border-gray-200">
        <div class="h-16 w-16 rounded-full bg-green-50 flex items-center justify-center text-green-500 mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-1">Tout est en ordre !</h3>
        <p class="text-gray-400 text-sm">Aucune alerte de sécurité n'a été détectée.</p>
    </div>
    {% endfor %}
</div>

<!-- 2FA Banner -->
<div class="mt-8 p-6 rounded-xl {% if app.user.is2faEnabled %}bg-green-50 border border-green-200{% else %}bg-brand/5 border border-brand/20{% endif %} relative overflow-hidden">
    <div class="relative z-10">
        {% if app.user.is2faEnabled %}
        <h3 class="text-base font-bold text-green-700 mb-1">Protection Maximale Activée</h3>
        <p class="text-green-600 text-sm max-w-2xl">Votre compte est protégé par l'authentification à deux facteurs (2FA).</p>
        <div class="mt-3 flex items-center justify-between">
            <div class="flex items-center space-x-2 text-green-600 font-semibold text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>2FA Activé</span>
            </div>
            <form method="POST" action="{{ path('app_2fa_setup') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('2fa_toggle') }}">
                <button type="submit" class="text-sm font-medium text-red-500 hover:text-red-700 border border-red-200 px-3 py-1.5 rounded-lg hover:bg-red-50 transition">Désactiver</button>
            </form>
        </div>
        {% else %}
        <h3 class="text-base font-bold text-brand-mid mb-1">Conseil de sécurité : Activez la 2FA</h3>
        <p class="text-gray-600 text-sm max-w-2xl">Activez l'authentification à deux facteurs pour une couche de protection supplémentaire.</p>
        <div class="mt-4">
            <form method="POST" action="{{ path('app_2fa_setup') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('2fa_toggle') }}">
                <button type="submit" class="btn btn-primary text-sm px-5">Activer maintenant</button>
            </form>
        </div>
        {% endif %}
    </div>
</div>
{% endblock body_connected %}
