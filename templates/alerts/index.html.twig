{% extends 'base.html.twig' %}

{% block title %}Alertes de Sécurité - SecureVault{% endblock %}

{% block body_connected %}
<div class="max-w-5xl mx-auto">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold">Alertes de Sécurité</h1>
            <p class="text-slate-400 mt-1">Restez informé des menaces potentielles sur votre coffre-fort.</p>
        </div>
        <div class="flex space-x-3">
            {% if alerts|filter(a => not a.isRead)|length > 0 %}
                <a href="{{ path('app_alerts_mark_all_read') }}" class="btn btn-ghost border border-white/10 text-sm">Marquer tout comme lu</a>
            {% endif %}
            <button class="btn btn-primary text-sm flex items-center space-x-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
                <span>Filtrer</span>
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="glass-card p-6 rounded-2xl border-l-4 border-red-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-slate-400 text-sm font-medium">Critique</p>
                    <p class="text-3xl font-bold mt-1 text-red-500">{{ alerts|filter(a => a.type == 'danger')|length }}</p>
                </div>
                <div class="h-12 w-12 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
            </div>
        </div>
        <div class="glass-card p-6 rounded-2xl border-l-4 border-amber-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-slate-400 text-sm font-medium">Avertissements</p>
                    <p class="text-3xl font-bold mt-1 text-amber-500">{{ alerts|filter(a => a.type == 'warning')|length }}</p>
                </div>
                <div class="h-12 w-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
        </div>
        <div class="glass-card p-6 rounded-2xl border-l-4 border-indigo-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-slate-400 text-sm font-medium">Informations</p>
                    <p class="text-3xl font-bold mt-1 text-indigo-400">{{ alerts|filter(a => a.type == 'info')|length }}</p>
                </div>
                <div class="h-12 w-12 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
        </div>
    </div>

    <div class="space-y-4">
        {% for alert in alerts %}
            <div class="glass-card rounded-2xl overflow-hidden hover:bg-white/10 transition-all duration-300 group {{ alert.isRead ? 'opacity-70' : '' }}">
                <div class="p-6 flex items-start space-x-6">
                    <div class="mt-1">
                        {% if alert.type == 'danger' %}
                            <div class="h-10 w-10 rounded-xl bg-red-500/20 flex items-center justify-center text-red-500 shadow-lg shadow-red-500/20">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            </div>
                        {% elseif alert.type == 'warning' %}
                            <div class="h-10 w-10 rounded-xl bg-amber-500/20 flex items-center justify-center text-amber-500 shadow-lg shadow-amber-500/20">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                        {% else %}
                            <div class="h-10 w-10 rounded-xl bg-indigo-500/20 flex items-center justify-center text-indigo-400 shadow-lg shadow-indigo-500/20">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                        {% endif %}
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between mb-1">
                            <h3 class="font-bold text-lg {{ alert.isRead ? 'text-slate-400' : 'text-white' }} flex items-center">
                                {{ alert.title }}
                                {% if not alert.isRead %}
                                    <span class="ml-2 h-2 w-2 rounded-full bg-indigo-500 shadow-lg shadow-indigo-500/50"></span>
                                {% endif %}
                            </h3>
                            <span class="text-xs text-slate-500">{{ alert.createdAt|date('d M Y, H:i') }}</span>
                        </div>
                        <p class="text-slate-400 group-hover:text-slate-300 transition-colors">{{ alert.description }}</p>
                        
                        <div class="mt-4 flex items-center justify-between">
                            <div class="flex space-x-2">
                                <span class="px-2 py-0.5 rounded-md bg-white/5 text-[10px] font-bold uppercase tracking-wider text-slate-500 border border-white/5">
                                    {{ alert.category }}
                                </span>
                            </div>
                            <div class="flex items-center space-x-4 opacity-0 group-hover:opacity-100 transition-opacity">
                                {% if not alert.isRead %}
                                    <a href="{{ path('app_alerts_mark_read', {id: alert.id}) }}" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 uppercase tracking-widest">Marquer comme lu</a>
                                {% endif %}
                                <a href="{{ path('app_alerts_dismiss', {id: alert.id}) }}" class="text-xs font-bold text-slate-500 hover:text-red-400 uppercase tracking-widest">Ignorer</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center py-20 glass-card rounded-3xl">
                <div class="h-20 w-20 rounded-full bg-green-500/10 flex items-center justify-center text-green-500 mx-auto mb-6">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <h3 class="text-xl font-bold mb-2">Tout est en ordre !</h3>
                <p class="text-slate-400">Aucune alerte de sécurité n'a été détectée pour le moment.</p>
            </div>
        {% endfor %}
    </div>


    <div class="mt-12 p-8 rounded-3xl {% if app.user.is2faEnabled %}bg-green-600/10 border-green-600/20{% else %}bg-indigo-600/10 border-indigo-600/20{% endif %} border relative overflow-hidden group">
        <div class="absolute top-0 right-0 p-8 {% if app.user.is2faEnabled %}text-green-600/20{% else %}text-indigo-600/20{% endif %} transform rotate-12 group-hover:scale-110 transition-transform">
            <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3z"/></svg>
        </div>
        <div class="relative z-10">
            {% if app.user.is2faEnabled %}
                <h3 class="text-lg font-bold text-green-400 mb-2">Protection Maximale Activée</h3>
                <p class="text-slate-300 max-w-2xl">Félicitations ! Votre compte est protégé par l'authentification à deux facteurs (2FA). Cela rend votre coffre-fort virtuellement impénétrable.</p>
                <div class="mt-4 flex items-center justify-between">
                    <div class="flex items-center space-x-2 text-green-500 font-bold text-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <span>2FA Activé</span>
                    </div>
                    <form method="POST" action="{{ path('app_2fa_setup') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('2fa_toggle') }}">
                        <button type="submit" class="btn btn-ghost text-sm border border-white/10 text-red-400 hover:text-red-300">Désactiver</button>
                    </form>
                </div>
            {% else %}
                <h3 class="text-lg font-bold text-indigo-400 mb-2">Conseil de sécurité : Activez la 2FA</h3>
                <p class="text-slate-300 max-w-2xl">Activez l'authentification à deux facteurs (2FA) sur votre compte pour une couche de protection supplémentaire. Un code vous sera envoyé par e-mail à chaque connexion.</p>
                <div class="mt-6 flex space-x-4">
                    <form method="POST" action="{{ path('app_2fa_setup') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('2fa_toggle') }}">
                        <button type="submit" class="btn btn-primary text-sm px-6">Activer maintenant</button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock body_connected %}
