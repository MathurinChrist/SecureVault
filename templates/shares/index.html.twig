{% extends 'base.html.twig' %}

{% block title %}Partages - SecureVault{% endblock %}

{% block body_connected %}
<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold">Partages</h1>
            <p class="text-slate-400 mt-1">Gérez les accès partagés avec d'autres utilisateurs ou équipes.</p>
        </div>
        <button class="btn btn-primary flex items-center space-x-2">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span>Nouveau partage</span>
        </button>
    </div>

    <div class="glass-card rounded-3xl p-12 text-center">
        <div class="h-24 w-24 rounded-full bg-indigo-600/10 flex items-center justify-center text-indigo-400 mx-auto mb-6">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
        </div>
        <h2 class="text-2xl font-bold mb-2">Collaboration Sécurisée</h2>
        <p class="text-slate-400 max-w-md mx-auto mb-8">Partagez des mots de passe ou des coffres entiers avec vos collègues en toute sécurité. Les accès peuvent être révoqués à tout moment.</p>
        <button class="btn btn-primary px-8">Commencer à partager</button>
    </div>
</div>
{% endblock body_connected %}
