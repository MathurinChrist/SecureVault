{# Utilisé par les modaux Ajouter ET Modifier. Variables : form, pwd_input_id #}

{# Coffre #}
<div>
    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
        Coffre <span class="text-red-400">*</span>
    </label>
    {{ form_widget(form.vault) }}
    {{ form_errors(form.vault) }}
</div>

{# Titre #}
<div>
    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
        Titre <span class="text-red-400">*</span>
    </label>
    {{ form_widget(form.title) }}
    {{ form_errors(form.title) }}
</div>

{# Identifiant #}
<div>
    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
        Identifiant
    </label>
    {{ form_widget(form.username) }}
</div>

{# Mot de passe + toggle #}
<div>
    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
        Mot de passe {% if form.vars.require_password ?? true %}<span class="text-red-400">*</span>{% endif %}
    </label>
    {# L'id réel de l'input est calculé par Symfony ; on le lit via vars.id #}
    {%- set real_pwd_id = form.plainPassword.vars.id -%}
    <div class="relative">
        {{ form_widget(form.plainPassword) }}
        <div class="absolute inset-y-0 right-0 flex items-center pr-2 space-x-0.5">
            <button
                type="button"
                onclick="generatePassword('{{ real_pwd_id }}', '{{ pwd_input_id }}-icon')"
                title="Générer un mot de passe sécurisé"
                class="p-1.5 rounded-lg text-slate-400 hover:text-indigo-400 hover:bg-white/5 transition"
            >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                </svg>
            </button>
            <button
                type="button"
                onclick="togglePwd('{{ real_pwd_id }}', '{{ pwd_input_id }}-icon')"
                class="p-1.5 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition"
            >
                <svg id="{{ pwd_input_id }}-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
            </button>
        </div>
    </div>
    {{ form_errors(form.plainPassword) }}
</div>

{# URL #}
<div>
    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
        URL du site
    </label>
    {{ form_widget(form.url) }}
</div>

{# Notes #}
<div>
    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
        Notes
    </label>
    {{ form_widget(form.notes) }}
</div>

{# Favori #}
<div class="flex items-center space-x-3 pt-1">
    {{ form_widget(form.favorite) }}
    <label class="text-sm text-slate-300 cursor-pointer select-none" for="{{ form.favorite.vars.id }}">
        Marquer comme favori
    </label>
</div>
