{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - SecureVault{% endblock %}

{% block body_connected %}
<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold">Mon Coffre-fort</h1>
            <p class="text-slate-400 mt-1">Gérez vos identifiants en toute sécurité.</p>
        </div>
        <button class="btn btn-primary flex items-center space-x-2">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            <span>Ajouter un mot de passe</span>
        </button>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="glass-card p-6 rounded-2xl">
            <p class="text-slate-400 text-sm font-medium">Mots de passe</p>
            <p class="text-3xl font-bold mt-2">12</p>
        </div>
        <div class="glass-card p-6 rounded-2xl">
            <p class="text-slate-400 text-sm font-medium">Coffres</p>
            <p class="text-3xl font-bold mt-2">2</p>
        </div>
        <div class="glass-card p-6 rounded-2xl">
            <p class="text-slate-400 text-sm font-medium">Alertes de sécurité</p>
            <p class="text-3xl font-bold mt-2 text-red-400">0</p>
        </div>
        <div class="glass-card p-6 rounded-2xl">
            <p class="text-slate-400 text-sm font-medium">Score de sécurité</p>
            <p class="text-3xl font-bold mt-2 text-green-400">98%</p>
        </div>
    </div>

    <!-- Table -->
    <div class="glass-card rounded-2xl overflow-hidden">
        <div class="p-6 border-b border-white/5 flex items-center justify-between">
            <h2 class="font-bold">Services récents</h2>
            <div class="flex space-x-2">
                <input type="text" placeholder="Rechercher..." class="bg-slate-800 border border-white/10 rounded-lg px-3 py-1 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500">
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-white/5 text-slate-400 text-xs uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Service</th>
                        <th class="px-6 py-4">Utilisateur</th>
                        <th class="px-6 py-4">Dernière modif.</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    <tr>
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-3">
                                <div class="h-8 w-8 rounded bg-indigo-500/20 flex items-center justify-center text-indigo-400">G</div>
                                <span class="font-medium">Google</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-slate-300">john.doe@gmail.com</td>
                        <td class="px-6 py-4 text-sm text-slate-500">Il y a 2 jours</td>
                        <td class="px-6 py-4 text-right">
                             <button class="text-slate-400 hover:text-white transition">Modifier</button>
                        </td>
                    </tr>
                    <tr>
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-3">
                                <div class="h-8 w-8 rounded bg-purple-500/20 flex items-center justify-center text-purple-400">G</div>
                                <span class="font-medium">GitHub</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-slate-300">jdoe_dev</td>
                        <td class="px-6 py-4 text-sm text-slate-500">Il y a 1 semaine</td>
                        <td class="px-6 py-4 text-right">
                             <button class="text-slate-400 hover:text-white transition">Modifier</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock body_connected %}
