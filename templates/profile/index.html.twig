{% extends 'base.html.twig' %}

{% block title %}Mon Profil - SecureVault{% endblock %}

{% block body_connected %}
<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <h1 class="text-3xl font-bold">Paramètres du profil</h1>
        <p class="text-slate-400 mt-1">Gérez vos informations personnelles et votre sécurité.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Sidebar Navigation -->
        <div class="space-y-2">
            <button onclick="showTab('info')" id="btn-info" class="w-full text-left px-4 py-3 rounded-xl transition-all font-medium bg-indigo-600/10 text-indigo-400 border border-indigo-600/20">
                Informations personnelles
            </button>
            <button onclick="showTab('security')" id="btn-security" class="w-full text-left px-4 py-3 rounded-xl transition-all font-medium text-slate-400 hover:bg-white/5">
                Sécurité & Mot de passe
            </button>
            <button class="w-full text-left px-4 py-3 rounded-xl transition-all font-medium text-slate-500 cursor-not-allowed">
                Sessions (Bientôt)
            </button>
            <button class="w-full text-left px-4 py-3 rounded-xl transition-all font-medium text-slate-500 cursor-not-allowed">
                Clé de chiffrement (Bientôt)
            </button>
        </div>

        <!-- Content -->
        <div class="md:col-span-2 space-y-6">
            
            <!-- Personal Info Tab -->
            <div id="tab-info" class="glass-card p-8 rounded-3xl space-y-8">
                {{ form_start(profileForm) }}
                    <div class="flex items-center space-x-6 mb-8">
                        <div class="relative group">
                            <img id="preview" src="{{ app.user.profileImage ? '/uploads/profiles/' ~ app.user.profileImage : 'https://ui-avatars.com/api/?name=' ~ app.user.firstName ~ '+' ~ app.user.lastName ~ '&background=random' }}" class="h-24 w-24 rounded-2xl border-2 border-white/10 group-hover:border-indigo-500 transition shadow-xl object-cover">
                            <div class="absolute inset-0 bg-black/40 rounded-2xl opacity-0 group-hover:opacity-100 flex items-center justify-center transition cursor-pointer">
                                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            </div>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg">Photo de profil</h3>
                            <p class="text-sm text-slate-500 mb-2">JPG, PNG ou WEBP. Max 2Mo.</p>
                            {{ form_widget(profileForm.profileImageFile, {'attr': {'class': 'text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-indigo-600/10 file:text-indigo-400 hover:file:bg-indigo-600/20'}}) }}
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-400 mb-1">Prénom</label>
                            {{ form_widget(profileForm.firstName, {'attr': {'class': 'w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 outline-none transition'}}) }}
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-400 mb-1">Nom</label>
                            {{ form_widget(profileForm.lastName, {'attr': {'class': 'w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 outline-none transition'}}) }}
                        </div>
                    </div>

                    <div class="mb-8">
                        <label class="block text-sm font-medium text-slate-400 mb-1">Email (Non modifiable)</label>
                        <input type="text" disabled value="{{ app.user.email }}" class="w-full bg-slate-800/50 border border-white/5 rounded-xl px-4 py-3 text-slate-500 cursor-not-allowed">
                    </div>

                    <button type="submit" class="btn btn-primary w-full py-4 uppercase tracking-widest text-xs">
                        Sauvegarder les modifications
                    </button>
                {{ form_end(profileForm) }}
            </div>

            <!-- Security Tab -->
            <div id="tab-security" class="glass-card p-8 rounded-3xl space-y-8 hidden">
                <h2 class="text-xl font-bold">Changer le mot de passe</h2>
                {{ form_start(passwordForm) }}
                    <div class="space-y-4 mb-8">
                        <div>
                            <label class="block text-sm font-medium text-slate-400 mb-1">Nouveau mot de passe</label>
                            {{ form_widget(passwordForm.plainPassword.first, {'attr': {'class': 'w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 outline-none transition'}}) }}
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-400 mb-1">Confirmer le mot de passe</label>
                            {{ form_widget(passwordForm.plainPassword.second, {'attr': {'class': 'w-full bg-slate-800 border border-white/10 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 outline-none transition'}}) }}
                        </div>
                    </div>

                    <button type="submit" class="btn bg-red-600 hover:bg-red-700 text-white w-full py-4 uppercase tracking-widest text-xs">
                        Mettre à jour le mot de passe
                    </button>
                {{ form_end(passwordForm) }}
            </div>

        </div>
    </div>
</div>

<script>
function showTab(tab) {
    // Hide all tabs
    document.getElementById('tab-info').classList.add('hidden');
    document.getElementById('tab-security').classList.add('hidden');
    
    // Reset buttons
    const btns = ['btn-info', 'btn-security'];
    btns.forEach(id => {
        const btn = document.getElementById(id);
        btn.classList.remove('bg-indigo-600/10', 'text-indigo-400', 'border', 'border-indigo-600/20');
        btn.classList.add('text-slate-400', 'hover:bg-white/5');
    });

    // Show selected tab
    document.getElementById('tab-' + tab).classList.remove('hidden');
    
    // Activate button
    const activeBtn = document.getElementById('btn-' + tab);
    activeBtn.classList.remove('text-slate-400', 'hover:bg-white/5');
    activeBtn.classList.add('bg-indigo-600/10', 'text-indigo-400', 'border', 'border-indigo-600/20');
}
</script>
{% endblock body_connected %}
