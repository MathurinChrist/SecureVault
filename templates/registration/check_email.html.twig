{% extends 'base.html.twig' %}

{% block title %}Vérifiez vos e-mails — SecureVault{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md text-center">

        <a href="{{ path('app_home') }}" class="inline-flex items-center space-x-2 mb-10">
            <div class="h-10 w-10 rounded-xl bg-indigo-600 flex items-center justify-center">
                <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
            </div>
            <span class="text-xl font-bold">SecureVault</span>
        </a>

        <div class="glass-card rounded-3xl p-10">
            <div class="h-20 w-20 rounded-full bg-indigo-500/10 flex items-center justify-center mx-auto mb-6">
                <svg class="h-10 w-10 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
            </div>

            <h1 class="text-2xl font-bold mb-3">Vérifiez vos e-mails</h1>
            <p class="text-slate-400 mb-2">
                Un e-mail de confirmation a été envoyé à
            </p>
            <p class="text-indigo-400 font-semibold mb-6">{{ email }}</p>
            <p class="text-slate-400 text-sm mb-8">
                Cliquez sur le lien dans l'e-mail pour activer votre compte.
                Le lien expire dans <strong class="text-slate-300">1 heure</strong>.
            </p>

            <div class="border-t border-white/10 pt-6">
                <p class="text-slate-500 text-sm mb-4">Vous n'avez pas reçu l'e-mail ?</p>
                <form method="post" action="{{ path('app_resend_verification') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}">
                    <input type="hidden" name="email" value="{{ email }}">
                    <button type="submit" class="btn btn-ghost border border-white/10 text-sm w-full">
                        Renvoyer l'e-mail de confirmation
                    </button>
                </form>
            </div>
        </div>

        <p class="mt-6 text-slate-500 text-sm">
            Déjà confirmé ?
            <a href="{{ path('app_login') }}" class="text-indigo-400 hover:text-indigo-300">Se connecter</a>
        </p>

    </div>
</div>
{% endblock %}
