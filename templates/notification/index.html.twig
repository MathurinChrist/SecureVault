{% extends 'base.html.twig' %}

{% block title %}Notifications - SecureVault{% endblock %}

{% block body_connected %}
{% set unread = notifications|filter(n => not n.isRead) %}

<div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="mb-6 flex items-start justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Notifications</h1>
            <p class="text-gray-500 mt-1 text-sm">{{ unread|length }} non lue{{ unread|length > 1 ? 's' : '' }}</p>
        </div>
        {% if unread|length > 0 %}
        <form method="post" action="{{ path('app_notifications_read_all') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('notif_read_all') }}">
            <button type="submit" class="flex items-center space-x-2 px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>Tout marquer comme lu</span>
            </button>
        </form>
        {% endif %}
    </div>

    {% if notifications is empty %}
    <div class="bg-white rounded-xl border border-gray-200 p-16 text-center">
        <div class="h-16 w-16 rounded-full bg-brand/10 flex items-center justify-center text-brand-mid mx-auto mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-1">Aucune notification</h3>
        <p class="text-gray-400 text-sm">Vous êtes à jour !</p>
    </div>
    {% else %}
    <div class="space-y-2">
        {% for notif in notifications %}
        {% set colors = {
            'success':  {bg: 'bg-green-50',        text: 'text-green-600',  border: 'border-l-green-500'},
            'warning':  {bg: 'bg-amber-50',         text: 'text-amber-600',  border: 'border-l-amber-500'},
            'security': {bg: 'bg-red-50',           text: 'text-red-600',    border: 'border-l-red-500'},
            'share':    {bg: 'bg-brand/10',     text: 'text-brand-mid', border: 'border-l-brand'},
            'info':     {bg: 'bg-sky-50',           text: 'text-sky-600',    border: 'border-l-sky-500'},
        } %}
        {% set c = colors[notif.type] ?? colors['info'] %}

        <div class="bg-white rounded-xl border border-gray-200 border-l-4 {{ c.border }} p-4 flex items-start space-x-4 {{ notif.isRead ? 'opacity-60' : '' }}">
            <div class="h-9 w-9 rounded-xl {{ c.bg }} flex items-center justify-center shrink-0 mt-0.5">
                {% if notif.type == 'success' %}
                    <svg class="w-4 h-4 {{ c.text }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {% elseif notif.type == 'warning' or notif.type == 'security' %}
                    <svg class="w-4 h-4 {{ c.text }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                {% elseif notif.type == 'share' %}
                    <svg class="w-4 h-4 {{ c.text }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                {% else %}
                    <svg class="w-4 h-4 {{ c.text }}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {% endif %}
            </div>
            <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between gap-2 mb-0.5">
                    <p class="font-semibold text-sm text-gray-900 flex items-center gap-2">
                        {{ notif.title }}
                        {% if not notif.isRead %}
                        <span class="h-2 w-2 rounded-full bg-brand inline-block shrink-0"></span>
                        {% endif %}
                    </p>
                    <span class="text-xs text-gray-400 shrink-0">{{ notif.createdAt|date('d/m/Y H:i') }}</span>
                </div>
                <p class="text-sm text-gray-500">{{ notif.message }}</p>
            </div>
            <div class="flex items-center space-x-1 shrink-0">
                {% if not notif.isRead %}
                <form method="post" action="{{ path('app_notification_read', {id: notif.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('notif_read_' ~ notif.id) }}">
                    <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:text-green-500 hover:bg-green-50 transition" title="Marquer comme lu">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </button>
                </form>
                {% endif %}
                <form method="post" action="{{ path('app_notification_dismiss', {id: notif.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('notif_dismiss_' ~ notif.id) }}">
                    <button type="submit" class="p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition" title="Supprimer">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </form>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
