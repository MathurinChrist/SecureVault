{% extends 'base.html.twig' %}
{% set standalone_layout = true %}

{% block title %}Vérifiez vos e-mails — SecureVault{% endblock %}

{% block visitor_navbar %}{% endblock %}
{% block visitor_footer %}{% endblock %}
{% block main_classes %}{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  .auth { font-family: 'Manrope', system-ui, sans-serif; }
  .auth ::selection { background: #E3FFCC; color: #142F32; }
</style>
{% endblock %}

{% block body %}
<div class="auth min-h-screen bg-canvas flex items-center justify-center p-4 sm:p-6">
  <div class="w-full max-w-[420px]">

    <a href="{{ path('app_home') }}" class="flex items-center justify-center gap-2.5 font-extrabold text-[18px] tracking-tight text-ink mb-8">
      <svg class="w-[30px] h-[30px] flex-none" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="13" stroke="#142F32" stroke-width="5" stroke-dasharray="56 26" stroke-linecap="round"/><circle cx="16" cy="16" r="4.5" fill="#2f7d5b"/></svg>
      SecureVault
    </a>

    <div class="bg-white rounded-[24px] border border-line shadow-[0_24px_60px_rgba(20,47,50,.12)] p-7 sm:p-9 text-center">

      <div class="inline-flex items-center justify-center h-14 w-14 rounded-2xl bg-brand/10 mb-4">
        <svg class="w-7 h-7 text-brand-mid" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>

      <h1 class="text-[22px] font-extrabold text-ink tracking-[-0.02em] mb-2">Vérifiez vos e-mails</h1>
      <p class="text-ink-muted text-[14px]">
        Si un compte existe avec cette adresse, un e-mail contenant un lien de réinitialisation vient de vous être envoyé.
      </p>
      <p class="text-ink-muted text-[13px] mt-3">
        Ce lien expire {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
      </p>

      <div class="mt-6 pt-6 border-t border-line">
        <p class="text-ink-muted text-[13px]">
          Vous n'avez rien reçu ? Vérifiez vos spams ou
          <a href="{{ path('app_forgot_password_request') }}" class="text-brand-mid font-bold hover:text-brand">réessayez</a>.
        </p>
      </div>
    </div>

    <div class="mt-6 text-center">
      <a href="{{ path('app_login') }}" class="text-[13px] text-ink-muted hover:text-ink-soft transition">← Retour à la connexion</a>
    </div>

  </div>
</div>
{% endblock %}
