{% extends 'base.html.twig' %}
{% set standalone_layout = true %}

{% block title %}Nouveau mot de passe — SecureVault{% endblock %}

{% block visitor_navbar %}{% endblock %}
{% block visitor_footer %}{% endblock %}
{% block main_classes %}{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  .auth { font-family: 'Manrope', system-ui, sans-serif; }
  .auth ::selection { background: #E3FFCC; color: #142F32; }
  .auth .field { width:100%; padding:13px 16px; background:#f4f6f7; border:1px solid #e0e4e8; border-radius:14px; color:#181d22; font-size:14px; outline:none; transition:.15s; }
  .auth .field::placeholder { color:rgba(106,116,128,.5); }
  .auth .field:focus { border-color:#142F32; background:#fff; box-shadow:0 0 0 3px rgba(20,47,50,.12); }
</style>
{% endblock %}

{% block body %}
<div class="auth min-h-screen bg-canvas flex items-center justify-center p-4 sm:p-6">
  <div class="w-full max-w-[420px]">

    <a href="{{ path('app_home') }}" class="flex items-center justify-center gap-2.5 font-extrabold text-[18px] tracking-tight text-ink mb-8">
      <svg class="w-[30px] h-[30px] flex-none" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="13" stroke="#142F32" stroke-width="5" stroke-dasharray="56 26" stroke-linecap="round"/><circle cx="16" cy="16" r="4.5" fill="#2f7d5b"/></svg>
      SecureVault
    </a>

    <div class="bg-white rounded-[24px] border border-line shadow-[0_24px_60px_rgba(20,47,50,.12)] p-7 sm:p-9">

      <div class="text-center mb-7">
        <div class="inline-flex items-center justify-center h-14 w-14 rounded-2xl bg-brand/10 mb-4">
          <svg class="w-7 h-7 text-brand-mid" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <h1 class="text-[22px] font-extrabold text-ink tracking-[-0.02em]">Nouveau mot de passe</h1>
        <p class="text-ink-muted text-[14px] mt-2">Choisissez un nouveau mot de passe pour votre compte.</p>
      </div>

      {{ form_start(resetForm) }}
        <div class="space-y-4">
          <div>
            <label for="{{ resetForm.plainPassword.first.vars.id }}" class="block text-[11px] font-bold text-ink-soft uppercase tracking-wider mb-1.5">Nouveau mot de passe</label>
            {{ form_widget(resetForm.plainPassword.first, {'attr': {'class': 'field', 'placeholder': '••••••••'}}) }}
            {{ form_errors(resetForm.plainPassword.first) }}
          </div>
          <div>
            <label for="{{ resetForm.plainPassword.second.vars.id }}" class="block text-[11px] font-bold text-ink-soft uppercase tracking-wider mb-1.5">Confirmer le mot de passe</label>
            {{ form_widget(resetForm.plainPassword.second, {'attr': {'class': 'field', 'placeholder': '••••••••'}}) }}
            {{ form_errors(resetForm.plainPassword.second) }}
          </div>
        </div>

        <button type="submit"
          class="w-full mt-6 bg-brand hover:bg-brand-light text-white font-bold py-3.5 rounded-full transition text-[14.5px] active:translate-y-px">
          Réinitialiser le mot de passe
        </button>
      {{ form_end(resetForm) }}
    </div>

  </div>
</div>
{% endblock %}
