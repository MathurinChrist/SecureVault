{% extends 'emails/base_email.html.twig' %}

{% block email_content %}
<h2 style="margin: 0 0 16px; font-size: 20px; font-weight: 700; color: #f1f5f9;">
    Votre code de connexion
</h2>
<p style="margin: 0 0 24px; font-size: 15px; color: #94a3b8; line-height: 1.6;">
    Bonjour {{ user.firstName }}, utilisez le code ci-dessous pour finaliser votre connexion à SecureVault.
    Ce code est valable pendant <strong style="color: #e2e8f0;">10 minutes</strong>.
</p>

<div style="text-align: center; margin: 32px 0;">
    <div style="
        display: inline-block;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 16px;
        padding: 24px 48px;
    ">
        <span style="
            font-size: 40px;
            font-weight: 800;
            letter-spacing: 12px;
            color: #ffffff;
            font-family: monospace;
        ">{{ code }}</span>
    </div>
</div>

<p style="margin: 0 0 8px; font-size: 14px; color: #64748b; line-height: 1.5;">
    Si vous n'avez pas tenté de vous connecter, ignorez cet e-mail et pensez à modifier votre mot de passe.
</p>
{% endblock %}
