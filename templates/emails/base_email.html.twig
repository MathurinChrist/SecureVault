<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SecureVault{% endblock %}</title>
    <style>
        body {
            background-color: #e9ecef;
            font-family: 'Manrope', 'Segoe UI', Tahoma, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            color: #181d22;
            -webkit-font-smoothing: antialiased;
        }
        .wrapper { width: 100%; padding: 40px 16px; }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background: #ffffff;
            border: 1px solid #e0e4e8;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 16px 40px rgba(20, 47, 50, 0.08);
        }
        .header {
            padding: 36px 40px 8px;
        }
        .brand {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: #181d22;
            text-decoration: none;
        }
        .content { padding: 16px 40px 8px; }
        h1 {
            font-size: 23px;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin: 16px 0 20px;
            color: #181d22;
        }
        p {
            font-size: 15px;
            line-height: 1.65;
            color: #6a7480;
            margin: 0 0 20px;
        }
        .button {
            display: inline-block;
            padding: 14px 32px;
            background-color: #142F32;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 999px;
            font-weight: 700;
            font-size: 15px;
            margin: 16px 0;
        }
        .tip-box {
            background: rgba(227, 255, 204, 0.35);
            border-left: 4px solid #2f7d5b;
            padding: 18px 20px;
            border-radius: 0 12px 12px 0;
            margin: 24px 0;
        }
        .tip-box p { margin: 0; color: #3c454c; font-size: 14px; }
        .footer {
            padding: 32px 40px;
            text-align: center;
            border-top: 1px solid #e0e4e8;
            background: #f4f6f7;
        }
        .footer p { font-size: 13px; margin: 0; color: #6a7480; }
        .footer a { color: #2f7d5b; text-decoration: none; font-size: 12px; }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <a href="#" class="brand">
                    <svg width="30" height="30" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="16" cy="16" r="13" stroke="#142F32" stroke-width="5" stroke-dasharray="56 26" stroke-linecap="round"/><circle cx="16" cy="16" r="4.5" fill="#2f7d5b"/></svg>
                    SecureVault
                </a>
            </div>

            <div class="content">
                {% block body %}{% endblock %}
            </div>

            <div class="footer">
                <p>&copy; {{ "now"|date("Y") }} SecureVault — Votre sécurité est notre priorité.</p>
                <div style="margin-top: 10px;">
                    <a href="#">Conditions d'utilisation</a>
                    <span style="color: #adb3bd; margin: 0 8px;">&bull;</span>
                    <a href="#">Politique de confidentialité</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
