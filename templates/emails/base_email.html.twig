<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SecureVault{% endblock %}</title>
    <style>
        body {
            background-color: #0f172a;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            color: #f8fafc;
        }
        .wrapper {
            width: 100%;
            padding: 40px 0;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }
        .header {
            padding: 40px 40px 20px;
            text-align: center;
        }
        .logo {
            font-size: 28px;
            font-weight: 800;
            color: #6366f1;
            text-decoration: none;
            letter-spacing: -1px;
        }
        .content {
            padding: 0 40px;
        }
        h1 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 24px;
            color: #ffffff;
        }
        p {
            font-size: 16px;
            line-height: 1.6;
            color: #94a3b8;
            margin-bottom: 24px;
        }
        .footer {
            padding: 40px;
            text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            background: rgba(15, 23, 42, 0.5);
        }
        .footer p {
            font-size: 13px;
            margin-bottom: 0;
        }
        .button {
            display: inline-block;
            padding: 14px 32px;
            background-color: #6366f1;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            margin: 20px 0;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }
        .tip-box {
            background: rgba(99, 102, 241, 0.1);
            border-left: 4px solid #6366f1;
            padding: 20px;
            border-radius: 0 12px 12px 0;
            margin: 24px 0;
        }
        .tip-box p {
            margin: 0;
            color: #c7d2fe;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <a href="#" class="logo">SecureVault</a>
            </div>
            
            <div class="content">
                {% block body %}{% endblock %}
            </div>
            
            <div class="footer">
                <p>&copy; {{ "now"|date("Y") }} SecureVault - Votre sécurité est notre priorité.</p>
                <div style="margin-top: 10px;">
                    <a href="#" style="color: #6366f1; text-decoration: none; font-size: 12px;">Conditions d'utilisation</a>
                    <span style="color: #475569; margin: 0 10px;">•</span>
                    <a href="#" style="color: #6366f1; text-decoration: none; font-size: 12px;">Politique de confidentialité</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
