{% extends 'base.html.twig' %}

{% block title %}Contactez-nous — SecureVault{% endblock %}

{% block main_classes %}{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  .auth { font-family: 'Manrope', system-ui, sans-serif; }
  .auth ::selection { background: #E3FFCC; color: #142F32; }
  .auth .field { width:100%; padding:13px 16px; background:#f4f6f7; border:1px solid #e0e4e8; border-radius:14px; color:#181d22; font-size:14px; outline:none; transition:.15s; font-family:inherit; }
  .auth .field::placeholder { color:rgba(106,116,128,.5); }
  .auth .field:focus { border-color:#142F32; background:#fff; box-shadow:0 0 0 3px rgba(20,47,50,.12); }
  textarea.field { resize:vertical; min-height:130px; }
  @keyframes authFloat { 0%,100%{transform:translateY(0) rotate(0)} 50%{transform:translateY(-14px) rotate(var(--rot,5deg))} }
  .auth-float { animation: authFloat var(--dur,4.5s) ease-in-out infinite; will-change:transform; }
  @media (prefers-reduced-motion: reduce){ .auth-float{ animation:none } }
</style>
{% endblock %}

{% block visitor_navbar %}{% endblock %}
{% block visitor_footer %}{% endblock %}

{% block body %}
<div class="auth relative min-h-screen bg-canvas text-ink overflow-hidden">

  {# ── Top header ── #}
  <header class="relative z-20">
    <div class="max-w-[1180px] mx-auto px-7 flex items-center justify-between h-[74px] gap-5">
      <a href="{{ path('app_home') }}" class="flex items-center gap-2.5 font-extrabold text-[18px] tracking-tight">
        <svg class="w-[30px] h-[30px] flex-none" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="13" stroke="#142F32" stroke-width="5" stroke-dasharray="56 26" stroke-linecap="round"/><circle cx="16" cy="16" r="4.5" fill="#2f7d5b"/></svg>
        SecureVault
      </a>
      <div class="flex items-center gap-4">
        <a href="{{ path('app_login') }}" class="hidden sm:inline text-[13.5px] font-semibold text-ink-muted hover:text-ink transition">Connexion</a>
        <a href="{{ path('app_register') }}" class="bg-brand hover:bg-brand-light text-white font-bold text-[13.5px] px-5 py-2.5 rounded-full transition">Créer un compte</a>
      </div>
    </div>
  </header>

  {# ── Floating animated icons ── #}
  <span style="--dur:4s;--rot:6deg;animation-delay:-.2s"  class="auth-float hidden lg:grid place-items-center absolute z-0 w-12 h-12 rounded-2xl shadow-[0_10px_30px_rgba(20,47,50,.10)] top-[22%] left-[8%] bg-white text-brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
  </span>
  <span style="--dur:5.2s;--rot:-7deg;animation-delay:-1.1s" class="auth-float hidden lg:grid place-items-center absolute z-0 w-11 h-11 rounded-2xl shadow-[0_10px_30px_rgba(20,47,50,.12)] top-[48%] left-[13%] bg-brand text-accent">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.8-7 9-4-1.2-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>
  </span>
  <span style="--dur:4.6s;--rot:8deg;animation-delay:-2.3s"  class="auth-float hidden lg:grid place-items-center absolute z-0 w-11 h-11 rounded-2xl shadow-[0_10px_30px_rgba(20,47,50,.10)] bottom-[16%] left-[10%] bg-accent text-brand">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
  </span>
  <span style="--dur:4.3s;--rot:-6deg;animation-delay:-.7s"  class="auth-float hidden lg:grid place-items-center absolute z-0 w-12 h-12 rounded-2xl shadow-[0_10px_30px_rgba(20,47,50,.10)] top-[24%] right-[8%] bg-white text-brand-mid">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8L20 10l-6.1 1.2L12 17l-1.9-5.8L4 10l6.1-1.2z"/></svg>
  </span>
  <span style="--dur:5.6s;--rot:7deg;animation-delay:-1.8s"  class="auth-float hidden lg:grid place-items-center absolute z-0 w-11 h-11 rounded-2xl shadow-[0_10px_30px_rgba(20,47,50,.12)] top-[50%] right-[13%] bg-charcoal text-accent">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93A10 10 0 004.93 19.07M19.07 19.07A10 10 0 014.93 4.93"/></svg>
  </span>
  <span style="--dur:4.8s;--rot:-8deg;animation-delay:-2.6s" class="auth-float hidden lg:grid place-items-center absolute z-0 w-11 h-11 rounded-2xl shadow-[0_10px_30px_rgba(20,47,50,.10)] bottom-[18%] right-[10%] bg-brand text-accent">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
  </span>

  {# ── Centered card ── #}
  <div class="relative z-10 flex items-center justify-center px-4 pb-16 pt-4 min-h-[calc(100vh-160px)]">
    <div class="w-full max-w-[480px]">
      <div class="bg-white rounded-[28px] border border-line shadow-[0_30px_70px_rgba(20,47,50,.14)] p-7 sm:p-10">

        {# Flash messages #}
        {% for message in app.flashes('success') %}
        <div class="mb-6 p-4 rounded-[14px] bg-brand-mid/[.08] border border-brand-mid/25 text-brand-mid text-[13.5px] flex items-start gap-3">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="font-semibold">{{ message }}</span>
        </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
        <div class="mb-6 p-3.5 rounded-[12px] bg-warn/[.08] border border-warn/20 text-warn text-[13.5px] flex items-center gap-2.5">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>{{ message }}</span>
        </div>
        {% endfor %}

        <span class="inline-flex items-center gap-1.5 bg-accent/40 text-brand font-bold text-[12.5px] px-3 py-1.5 rounded-full mb-5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Support SecureVault
        </span>

        <h1 class="text-[28px] font-extrabold text-ink tracking-[-0.03em] mb-1.5">Contactez-<span class="text-brand-mid">nous.</span></h1>
        <p class="text-ink-muted text-[14.5px] mb-7">Une question, un problème ? On vous répond sous 48 h.</p>

        <form method="post" action="{{ path('app_contact') }}" class="space-y-4">
          <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-[11px] font-bold text-ink-soft uppercase tracking-wider mb-1.5">Nom complet</label>
              <input type="text" name="name" id="name" class="field" placeholder="Marie Dupont" required autocomplete="name">
            </div>
            <div>
              <label for="email" class="block text-[11px] font-bold text-ink-soft uppercase tracking-wider mb-1.5">E-mail</label>
              <input type="email" name="email" id="email" class="field" placeholder="vous@exemple.com" required autocomplete="email">
            </div>
          </div>

          <div>
            <label for="subject" class="block text-[11px] font-bold text-ink-soft uppercase tracking-wider mb-1.5">Sujet</label>
            <select name="subject" id="subject" class="field" required>
              <option value="" disabled selected>Choisir un sujet…</option>
              <option value="Question générale">Question générale</option>
              <option value="Problème technique">Problème technique</option>
              <option value="Facturation / abonnement">Facturation / abonnement</option>
              <option value="Signalement de sécurité">Signalement de sécurité</option>
              <option value="Partenariat">Partenariat</option>
              <option value="Autre">Autre</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-[11px] font-bold text-ink-soft uppercase tracking-wider mb-1.5">Message</label>
            <textarea name="message" id="message" class="field" placeholder="Décrivez votre demande en détail…" required minlength="10"></textarea>
          </div>

          <button type="submit"
            class="w-full bg-brand hover:bg-brand-light text-white font-bold py-3.5 rounded-full transition text-[14.5px] mt-2 active:translate-y-px flex items-center justify-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Envoyer le message
          </button>
        </form>
      </div>

      {# trust signals #}
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mt-7 text-[13px] text-ink-muted">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-mid" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Réponse sous 48 h
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-mid" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Confirmation par e-mail
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-mid" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Données sécurisées
        </span>
      </div>
    </div>
  </div>
</div>
{% endblock %}
