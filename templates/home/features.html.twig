{% extends 'base.html.twig' %}

{% block title %}Fonctionnalités - SecureVault{% endblock %}

{% block body %}
<div class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold sm:text-6xl mb-6">Tout ce dont vous avez besoin.</h1>
        <p class="text-xl text-slate-400 max-w-3xl mx-auto">Découvrez les outils puissants qui font de SecureVault la plateforme la plus sûre pour vos données.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="glass-card p-10 rounded-3xl">
            <h3 class="text-2xl font-bold mb-4">Générateur de mots de passe</h3>
            <p class="text-slate-400">Générez instantanément des mots de passe complexes et uniques pour chaque service.</p>
        </div>
        <div class="glass-card p-10 rounded-3xl">
            <h3 class="text-2xl font-bold mb-4">Authentification à deux facteurs</h3>
            <p class="text-slate-400">Ajoutez une couche de protection supplémentaire avec le support TOTP et WebAuthn.</p>
        </div>
        <div class="glass-card p-10 rounded-3xl">
            <h3 class="text-2xl font-bold mb-4">Accessibilité multi-plateforme</h3>
            <p class="text-slate-400">Accédez à vos données sur n'importe quel appareil, partout dans le monde.</p>
        </div>
    </div>
</div>
{% endblock %}
