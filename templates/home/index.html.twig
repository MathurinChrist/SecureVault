{% extends 'base.html.twig' %}

{% block title %}SecureVault — Gestion de mots de passe{% endblock %}

{% block main_classes %}{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  .home-page, .home-nav, .home-foot { font-family: 'Manrope', system-ui, sans-serif; }
  .mono { font-family: 'IBM Plex Mono', ui-monospace, Menlo, monospace; }
  .home-page ::selection { background: #E3FFCC; color: #142F32; }

  /* range slider */
  .sv-range { width:100%; accent-color:#142F32; }

  /* generated password coloring */
  .gen-pw .d { color:#2f7d5b; }
  .gen-pw .y { color:#c4453a; }

  /* generator option toggles */
  .sv-opt { display:flex; align-items:center; gap:9px; padding:9px 12px; border:1px solid #e0e4e8; border-radius:10px; font-size:13px; font-weight:600; color:#3c454c; cursor:pointer; user-select:none; transition:all .12s; }
  .sv-opt .box { width:17px; height:17px; border-radius:5px; flex:none; border:1.5px solid #777C90; display:grid; place-items:center; color:#fff; transition:all .12s; }
  .sv-opt .box svg { opacity:0; transition:opacity .12s; }
  .sv-opt.on { color:#181d22; border-color:#142F32; }
  .sv-opt.on .box { background:#142F32; border-color:#142F32; }
  .sv-opt.on .box svg { opacity:1; }

  /* sticky header border on scroll */
  #svHdr.scrolled { border-bottom-color:#e0e4e8; }

  /* orbit nodes */
  .orbit-node { position:absolute; background:#fff; border:1px solid #e0e4e8; border-radius:13px; width:50px; height:50px; display:grid; place-items:center; box-shadow:0 4px 16px rgba(20,47,50,.10); transform:translate(-50%,-50%); font-weight:800; color:#142F32; transition:box-shadow .2s, transform .2s; }
  .orbit-node:hover { box-shadow:0 8px 28px rgba(20,47,50,.18); transform:translate(-50%,-50%) scale(1.13); }

  /* outer ring slow rotation */
  @keyframes orbitSpin  { from{transform:rotate(0deg)}   to{transform:rotate(360deg)} }
  @keyframes orbitSpinR { from{transform:rotate(360deg)} to{transform:rotate(0deg)} }
  /* counter-rotate nodes so icons stay upright */
  @keyframes iconUpright  { from{transform:translate(-50%,-50%) rotate(0deg)}   to{transform:translate(-50%,-50%) rotate(-360deg)} }
  @keyframes iconUprightR { from{transform:translate(-50%,-50%) rotate(360deg)} to{transform:translate(-50%,-50%) rotate(0deg)} }
  /* float — keeps centering transform + adds vertical movement */
  @keyframes orbitFloat {
    0%,100% { transform: translate(-50%,-50%) translateY(0)     rotate(var(--ir,0deg)); }
    50%     { transform: translate(-50%,-50%) translateY(-11px)  rotate(var(--ir,0deg)); }
  }

  #orbitRing1 { position:absolute; border:1.5px dashed rgba(20,47,50,.12); border-radius:50%; top:50%; left:50%; transform:translate(-50%,-50%); animation:orbitSpin 22s linear infinite; pointer-events:none; }
  #orbitRing2 { position:absolute; border:1.5px dashed rgba(20,47,50,.08); border-radius:50%; top:50%; left:50%; transform:translate(-50%,-50%); animation:orbitSpinR 16s linear infinite; pointer-events:none; }

  @media (prefers-reduced-motion: reduce) {
    #orbitRing1, #orbitRing2 { animation:none; }
    .orbit-node { animation:none !important; }
  }

  /* floating hero icons */
  @keyframes svFloat {
    0%   { transform: translateY(0)      rotate(0deg); }
    50%  { transform: translateY(-13px)  rotate(var(--rot, 5deg)); }
    100% { transform: translateY(0)      rotate(0deg); }
  }
  .hero-float { animation: svFloat var(--dur, 4s) ease-in-out infinite; will-change: transform; }
  @media (prefers-reduced-motion: reduce) { .hero-float { animation: none; } }
</style>
{% endblock %}

