<script>
(function(){
  /* ---------- orbit nodes (brand logos + animations) ---------- */
  const orbit = document.getElementById('orbit');
  if (orbit) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* Animated dashed rings */
    const w = orbit.clientWidth || 400;
    [[w*.78,'orbitRing1'],[w*.52,'orbitRing2']].forEach(([size,id])=>{
      const r = document.createElement('div');
      r.id = id;
      r.style.cssText = `width:${size}px;height:${size}px;`;
      orbit.appendChild(r);
    });

    const brands = [
      /* Google */
      {name:'Google', c:'#4285F4', svg:'<path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z" fill="#4285F4"/><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133l3.075 2.39C24.907 18.867 26 15.867 26 12c0-.76-.053-1.467-.173-2.053H12.48z" fill="#4285F4"/>'},
      /* GitHub */
      {name:'GitHub', c:'#181717', svg:'<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" fill="#181717"/>'},
      /* Spotify */
      {name:'Spotify', c:'#1DB954', svg:'<path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.84-.179-.96-.6-.12-.421.18-.84.6-.96 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.42 1.56-.299.421-1.02.599-1.56.3z" fill="#1DB954"/>'},
      /* Apple */
      {name:'Apple', c:'#333', svg:'<path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701" fill="#333"/>'},
      /* Dropbox */
      {name:'Dropbox', c:'#0061FF', svg:'<path d="M6 1.807L0 5.629l6 3.822 6.001-3.822zM18 1.807l-6 3.822 6 3.822 6-3.822zM0 13.274l6 3.822 6.001-3.822L6 9.452zM18 9.452l-6 3.822 6 3.822 6-3.822zM6 18.371l6.001 3.822 6-3.822-6-3.822z" fill="#0061FF"/>'},
      /* Microsoft */
      {name:'Microsoft', c:'#00A4EF', svg:'<path d="M0 0h11.4v11.4H0z" fill="#F25022"/><path d="M12.6 0H24v11.4H12.6z" fill="#7FBA00"/><path d="M0 12.6h11.4V24H0z" fill="#00A4EF"/><path d="M12.6 12.6H24V24H12.6z" fill="#FFB900"/>'},
    ];

    brands.forEach((b,i)=>{
      const ang  = (i/brands.length)*Math.PI*2 - Math.PI/2;
      const rad  = i%2===0 ? 39 : 26;
      const x    = 50 + Math.cos(ang)*rad;
      const y    = 50 + Math.sin(ang)*rad;
      const n    = document.createElement('div');
      n.className = 'orbit-node';
      n.title     = b.name;
      n.style.top  = y+'%';
      n.style.left = x+'%';
      n.innerHTML  = `<svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">${b.svg}</svg>`;

      /* independent float per icon — desynchronised */
      if (!reduced) {
        const dur   = 2.6 + i * 0.42;   /* 2.6s … 4.7s */
        const delay = -(i * 0.7);        /* staggered start */
        const rot   = (i % 2 ? 1 : -1) * (3 + i * 1.5); /* subtle tilt */
        n.style.setProperty('--ir', rot + 'deg');
        n.style.animation = `orbitFloat ${dur}s ease-in-out ${delay}s infinite`;
      }
      orbit.appendChild(n);
    });
  }

  /* ---------- generator ---------- */
  const opts = {upper:true,lower:true,num:true,sym:true};
  let len = 16, current = '';

  function gen(){
    const L='abcdefghijkmnpqrstuvwxyz',U='ABCDEFGHJKLMNPQRSTUVWXYZ',N='23456789',S='!@#$%^&*-_=+?';
    let set=''; if(opts.lower)set+=L; if(opts.upper)set+=U; if(opts.num)set+=N; if(opts.sym)set+=S;
    if(!set){set=L;}
    const must=[]; if(opts.lower)must.push(L); if(opts.upper)must.push(U); if(opts.num)must.push(N); if(opts.sym)must.push(S);
    const out=must.map(s=>s[Math.floor(Math.random()*s.length)]);
    for(let i=out.length;i<len;i++)out.push(set[Math.floor(Math.random()*set.length)]);
    for(let i=out.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[out[i],out[j]]=[out[j],out[i]];}
    return out.slice(0,len).join('');
  }
  function entropy(){let pool=0;if(opts.lower)pool+=25;if(opts.upper)pool+=24;if(opts.num)pool+=8;if(opts.sym)pool+=12;return Math.round(len*Math.log2(pool||25));}

  function render(){
    current=gen();
    document.getElementById('gPw').innerHTML = current.split('').map(c=>{
      if(/[0-9]/.test(c))return '<span class="d">'+c+'</span>';
      if(/[^a-zA-Z0-9]/.test(c))return '<span class="y">'+c+'</span>';
      return c;
    }).join('');
    const bits=entropy();
    const lvl = bits>=110?['Excellent','#2f7d5b',4]:bits>=80?['Fort','#2f7d5b',3]:bits>=55?['Moyen','#b7791f',2]:['Faible','#c4453a',1];
    document.getElementById('gStrTxt').textContent=lvl[0];
    document.getElementById('gStrTxt').style.color=lvl[1];
    document.querySelector('#gStr span').style.background=lvl[1];
    [...document.querySelectorAll('#gBars i')].forEach((b,i)=>b.style.background = i<lvl[2]?lvl[1]:'#e0e4e8');
    const crack = bits>=120?'des siècles':bits>=95?'des millénaires':bits>=75?'3 000 ans':bits>=58?'34 ans':bits>=42?'2 heures':'instantané';
    document.getElementById('gCrack').textContent=crack;
  }

  function toast(msg){const t=document.getElementById('toast');document.getElementById('toastMsg').textContent=msg;t.classList.remove('opacity-0','translate-y-5');t.classList.add('opacity-100');clearTimeout(t._t);t._t=setTimeout(()=>{t.classList.remove('opacity-100');t.classList.add('opacity-0','translate-y-5');},1900);}
  function copy(){if(navigator.clipboard)navigator.clipboard.writeText(current);toast('Mot de passe copié');}

  document.getElementById('gLen').addEventListener('input',e=>{len=+e.target.value;document.getElementById('gLenV').textContent=len;render();});
  document.getElementById('gRe').addEventListener('click',render);
  document.getElementById('gCopy').addEventListener('click',copy);
  document.getElementById('gCopy2').addEventListener('click',copy);
  document.querySelectorAll('.sv-opt').forEach(o=>o.addEventListener('click',()=>{
    const k=o.dataset.k; const enabled=Object.keys(opts).filter(x=>opts[x]);
    if(opts[k]&&enabled.length===1)return;
    opts[k]=!opts[k]; o.classList.toggle('on',opts[k]); render();
  }));
  render();

  /* ---------- header border on scroll ---------- */
  const hdr=document.getElementById('svHdr');
  addEventListener('scroll',()=>hdr.classList.toggle('scrolled',scrollY>10));
})();
</script>
{% endverbatim %}
{% endblock %}

