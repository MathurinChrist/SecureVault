  {# Mobile drawer #}
  <div id="svMenu" class="hidden lg:hidden bg-canvas border-t border-line px-5 pb-5 pt-3 space-y-1">
    <a href="{{ path('app_home') }}"          onclick="svMenuToggle()" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-[15px] font-semibold text-brand bg-brand/[.06]">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Accueil
    </a>
    <a href="{{ path('app_home') }}#features" onclick="svMenuToggle()" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-[15px] font-semibold text-ink-soft hover:text-ink hover:bg-brand/[.04] transition">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      Fonctionnalités
    </a>
    <a href="{{ path('app_home') }}#pricing"  onclick="svMenuToggle()" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-[15px] font-semibold text-ink-soft hover:text-ink hover:bg-brand/[.04] transition">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8L20 10l-6.1 1.2L12 17l-1.9-5.8L4 10l6.1-1.2z"/></svg>
      Tarifs
    </a>
    <a href="{{ path('app_home') }}#security" onclick="svMenuToggle()" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-[15px] font-semibold text-ink-soft hover:text-ink hover:bg-brand/[.04] transition">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.8-7 9-4-1.2-7-4.5-7-9V6l7-3z"/></svg>
      Sécurité
    </a>
    <a href="{{ path('app_contact') }}" onclick="svMenuToggle()" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-[15px] font-semibold text-ink-soft hover:text-ink hover:bg-brand/[.04] transition">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      Contact
    </a>
    <div class="pt-3 border-t border-line flex flex-col gap-2">
      <a href="{{ path('app_register') }}" class="w-full text-center bg-brand hover:bg-brand-light text-white font-bold text-[14.5px] py-3 rounded-full transition">Créer un compte</a>
    </div>
  </div>
</header>

<script>
function svMenuToggle() {
  const menu = document.getElementById('svMenu');
  const ico  = document.getElementById('svMenuIco');
  const open = menu.classList.toggle('hidden');
  ico.innerHTML = open
    ? '<path d="M4 6h16M4 12h16M4 18h16"/>'
    : '<path d="M18 6L6 18M6 6l12 12"/>';
}
// close on resize to desktop
window.addEventListener('resize', function () {
  if (window.innerWidth >= 1024) {
    document.getElementById('svMenu').classList.add('hidden');
    document.getElementById('svMenuIco').innerHTML = '<path d="M4 6h16M4 12h16M4 18h16"/>';
  }
});
</script>
{% endblock %}

{% block body %}
