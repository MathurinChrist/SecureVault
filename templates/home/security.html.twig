{% extends 'base.html.twig' %}

{% block title %}Sécurité - SecureVault{% endblock %}

{% block body %}
<div class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative glass-card p-12 rounded-[3rem] overflow-hidden">
        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div>
                <h1 class="text-5xl font-extrabold mb-8">Zéro Connaissance. Sécurité Totale.</h1>
                <p class="text-lg text-slate-400 mb-8 leading-relaxed">
                    Nous utilisons le chiffrement **AES-256-GCM** avec dérivation de clé **Argon2id**. Vos données sont chiffrées sur votre appareil avant même d'atteindre nos serveurs. Nous ne pouvons JAMAIS voir vos mots de passe.
                </p>
                <ul class="space-y-4">
                    <li class="flex items-center space-x-3 text-green-400">
                        <svg class="w-6 h-6 shadow-[0_0_15px_rgba(34,197,94,0.5)] bg-green-500 rounded-full text-white p-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        <span class="text-slate-200">Chiffrement de bout en bout</span>
                    </li>
                    <li class="flex items-center space-x-3 text-green-400">
                        <svg class="w-6 h-6 shadow-[0_0_15px_rgba(34,197,94,0.5)] bg-green-500 rounded-full text-white p-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        <span class="text-slate-200">Audit de sécurité régulier</span>
                    </li>
                </ul>
            </div>
            <div class="hidden lg:block">
                <div class="grid grid-cols-2 gap-4">
                    <div class="aspect-square glass-card rounded-3xl flex items-center justify-center text-4xl">🔐</div>
                    <div class="aspect-square glass-card rounded-3xl mt-12 flex items-center justify-center text-4xl">🛠️</div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
