<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SecureVault{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🛡️</text></svg>">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.tailwindcss.com"></script>
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            primary: '#4F46E5',
                            secondary: '#6366F1',
                            dark: '#0f172a',
                            glass: 'rgba(255, 255, 255, 0.05)',
                        }
                    }
                }
            }
        </script>
        <style type="text/tailwindcss">
            @layer base {
                body {
                    @apply bg-[#0f172a] text-slate-100 antialiased font-sans;
                }
            }
            @layer components {
                .btn {
                    @apply px-4 py-2 rounded-xl font-semibold transition-all duration-200 transform active:scale-95 disabled:opacity-50;
                }
                .btn-primary {
                    @apply bg-indigo-600 text-white hover:bg-indigo-700 shadow-lg shadow-indigo-500/20 active:shadow-none;
                }
                .btn-ghost {
                    @apply hover:bg-white/10 text-slate-300 hover:text-white;
                }
                .glass-card {
                    @apply bg-white/5 backdrop-blur-xl border border-white/10 shadow-2xl;
                }
                .nav-link {
                    @apply flex items-center space-x-3 px-4 py-3 rounded-xl transition-all duration-200 hover:bg-white/5 text-slate-400 hover:text-white;
                }
                .nav-link-active {
                    @apply bg-indigo-600/10 text-indigo-400 border border-indigo-600/20;
                }
            }
        </style>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body class="min-h-screen flex">
        {% if app.user %}
            <!-- DASHBOARD LAYOUT (CONNECTED) -->
            
            <!-- Sidebar -->
            <aside class="w-72 border-r border-white/5 bg-[#0b1222] hidden lg:flex flex-col fixed inset-y-0 z-50">
                <div class="p-6 flex items-center space-x-3">
                    <span class="text-2xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">SecureVault</span>
                </div>
                
                <nav class="flex-1 px-4 space-y-2 mt-4">
                    <a href="{{ path('app_dashboard') }}" class="nav-link {{ app.request.get('_route') == 'app_dashboard' ? 'nav-link-active' : '' }}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                        <span>Tableau de bord</span>
                    </a>
                    <a href="{{ path('app_vaults') }}" class="nav-link {{ app.request.get('_route') starts with 'app_vault' ? 'nav-link-active' : '' }}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                        <span>Mes coffres</span>
                    </a>
                    <a href="{{ path('app_passwords') }}" class="nav-link {{ app.request.get('_route') starts with 'app_password' ? 'nav-link-active' : '' }}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                        <span>Mots de passe</span>
                    </a>
                    <a href="{{ path('app_shares') }}" class="nav-link {{ app.request.get('_route') == 'app_shares' ? 'nav-link-active' : '' }}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                        <span>Partages</span>
                    </a>
                    <a href="{{ path('app_alerts') }}" class="nav-link {{ app.request.get('_route') == 'app_alerts' ? 'nav-link-active' : '' }}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                        <span>Alertes sécurité</span>
                    </a>
                    
                    <div class="pt-4 pb-2 px-4 uppercase text-[10px] font-bold text-slate-500 tracking-widest">Personnel</div>
                    
                    <a href="{{ path('app_profile') }}" class="nav-link {{ app.request.get('_route') == 'app_profile' ? 'nav-link-active' : '' }}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <span>Mon Profil</span>
                    </a>
                    
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="pt-4 pb-2 px-4 uppercase text-[10px] font-bold text-slate-500 tracking-widest">Admin</div>
                        <a href="#" class="nav-link">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37a1.724 1.724 0 002.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            <span>Administration</span>
                        </a>
                    {% endif %}
                </nav>
                
                <div class="p-4 border-t border-white/5">
                    <a href="{{ path('app_logout') }}" class="nav-link text-red-400 hover:bg-red-500/10">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                        <span>Se déconnecter</span>
                    </a>
                </div>
            </aside>

            <!-- Main Content Area -->
            <div class="flex-1 lg:ml-72 flex flex-col">
                <!-- Top Navbar -->
                <header class="h-16 border-b border-white/5 bg-[#0f172a]/80 backdrop-blur-md flex items-center justify-between px-8 sticky top-0 z-40">
                    <div class="flex items-center flex-1 max-w-xl">
                        <div class="relative w-full">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-500">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                            </span>
                            <input type="text" placeholder="Rechercher partout..." class="block w-full pl-10 pr-3 py-2 bg-white/5 border border-white/10 rounded-xl text-sm placeholder-slate-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition">
                        </div>
                    </div>
                    
                    <div class="flex items-center space-x-6 ml-8">
                        <button class="text-slate-400 hover:text-white relative">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                            <span class="absolute top-0 right-0 h-2 w-2 bg-red-500 rounded-full border-2 border-[#0f172a]"></span>
                        </button>
                        
                        <a href="{{ path('app_profile') }}" class="flex items-center space-x-3 group">
                            <div class="text-right hidden sm:block">
                                <p class="text-sm font-semibold">{{ app.user.firstName }} {{ app.user.lastName }}</p>
                                <p class="text-xs text-slate-500">Utilisateur</p>
                            </div>
                            <img src="{{ app.user.profileImage ? '/uploads/profiles/' ~ app.user.profileImage : 'https://ui-avatars.com/api/?name=' ~ app.user.firstName ~ '+' ~ app.user.lastName ~ '&background=random' }}" class="h-10 w-10 rounded-xl border border-white/10 group-hover:border-indigo-500 transition-colors">
                        </a>
                    </div>
                </header>

                <main class="p-8">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="mb-6 p-4 rounded-xl glass-card flex items-center space-x-3 {% if label == 'success' %}text-green-400{% else %}text-red-400{% endif %}">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                <span>{{ message }}</span>
                            </div>
                        {% endfor %}
                    {% endfor %}
                    
                    {% block body_connected %}{% endblock %}
                </main>
            </div>

        {% else %}
            <!-- VISITOR LAYOUT -->
            <div class="flex-1 flex flex-col">
                <nav class="h-20 bg-[#0f172a]/80 backdrop-blur-md fixed top-0 w-full z-50 border-b border-white/5 px-8 flex items-center justify-between">
                    <div class="flex items-center space-x-12">
                        <a href="{{ path('app_home') }}" class="text-2xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">SecureVault</a>
                        <div class="hidden lg:flex items-center space-x-8 text-sm font-medium">
                            <a href="{{ path('app_home') }}" class="hover:text-indigo-400 transition">Accueil</a>
                            <a href="{{ path('app_features') }}" class="hover:text-indigo-400 transition">Fonctionnalités</a>
                            <a href="{{ path('app_security') }}" class="hover:text-indigo-400 transition">Sécurité</a>
                            <a href="{{ path('app_pricing') }}" class="hover:text-indigo-400 transition">Tarifs</a>
                        </div>
                    </div>
                    
                    <div class="flex items-center space-x-4">
                        <a href="{{ path('app_login') }}" class="btn btn-ghost">Connexion</a>
                        <a href="{{ path('app_register') }}" class="btn btn-primary">Créer un compte</a>
                    </div>
                </nav>

                <main class="pt-20">
                    {% block body %}{% endblock %}
                </main>

                <footer class="bg-black/20 border-t border-white/5 py-12 px-8">
                    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
                        <div class="col-span-2">
                            <span class="text-2xl font-bold text-white mb-6 block">SecureVault</span>
                            <p class="text-slate-400 max-w-sm">La solution de gestion de mots de passe de référence pour les entreprises et les particuliers soucieux de leur sécurité numérique.</p>
                        </div>
                        <div>
                            <h4 class="text-white font-bold mb-4">Produits</h4>
                            <ul class="text-slate-400 space-y-2 text-sm">
                                <li><a href="#" class="hover:text-white transition">Fonctionnalités</a></li>
                                <li><a href="#" class="hover:text-white transition">Sécurité</a></li>
                                <li><a href="#" class="hover:text-white transition">Tarifs</a></li>
                                <li><a href="#" class="hover:text-white transition">Entreprise</a></li>
                            </ul>
                        </div>
                        <div>
                            <h4 class="text-white font-bold mb-4">Légal</h4>
                            <ul class="text-slate-400 space-y-2 text-sm">
                                <li><a href="#" class="hover:text-white transition">Confidentialité</a></li>
                                <li><a href="#" class="hover:text-white transition">Conditions d'utilisation</a></li>
                                <li><a href="#" class="hover:text-white transition">Contact</a></li>
                            </ul>
                        </div>
                    </div>
                </footer>
            </div>
        {% endif %}
    </body>
</html>
