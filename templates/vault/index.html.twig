{% extends 'base.html.twig' %}

{% block title %}Mes Coffres - SecureVault{% endblock %}

{% block body_connected %}

{% set palette = [
    {bg: 'bg-indigo-500/20', text: 'text-indigo-400', ring: 'ring-indigo-500/30'},
    {bg: 'bg-purple-500/20', text: 'text-purple-400', ring: 'ring-purple-500/30'},
    {bg: 'bg-emerald-500/20', text: 'text-emerald-400', ring: 'ring-emerald-500/30'},
    {bg: 'bg-amber-500/20', text: 'text-amber-400', ring: 'ring-amber-500/30'},
    {bg: 'bg-rose-500/20', text: 'text-rose-400', ring: 'ring-rose-500/30'},
    {bg: 'bg-sky-500/20', text: 'text-sky-400', ring: 'ring-sky-500/30'},
    {bg: 'bg-teal-500/20', text: 'text-teal-400', ring: 'ring-teal-500/30'},
] %}

<div class="space-y-8">

    {# ---- Header ---- #}
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold">Mes Coffres</h1>
            <p class="text-slate-400 mt-1">Organisez vos mots de passe par catégorie.</p>
        </div>
        <button onclick="openCreateModal()" class="btn btn-primary flex items-center space-x-2">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            <span>Nouveau coffre</span>
        </button>
    </div>

    {# ---- Stats ---- #}
    {% set active_vaults   = vaults|filter(v => not v.archived) %}
    {% set archived_vaults = vaults|filter(v => v.archived) %}
    {% set total_entries   = 0 %}
    {% for v in vaults %}{% set total_entries = total_entries + v.passwordEntries|length %}{% endfor %}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card p-6 rounded-2xl">
            <p class="text-slate-400 text-sm font-medium">Coffres actifs</p>
            <p class="text-3xl font-bold mt-2">{{ active_vaults|length }}</p>
        </div>
        <div class="glass-card p-6 rounded-2xl">
            <p class="text-slate-400 text-sm font-medium">Coffres archivés</p>
            <p class="text-3xl font-bold mt-2 text-slate-500">{{ archived_vaults|length }}</p>
        </div>
        <div class="glass-card p-6 rounded-2xl">
            <p class="text-slate-400 text-sm font-medium">Total mots de passe</p>
            <p class="text-3xl font-bold mt-2 text-indigo-400">{{ total_entries }}</p>
        </div>
    </div>

    {# ---- Vaults actifs ---- #}
    {% if vaults is empty %}
        <div class="glass-card rounded-2xl p-16 text-center">
            <div class="h-20 w-20 mx-auto bg-indigo-500/10 rounded-3xl flex items-center justify-center mb-6">
                <svg class="h-10 w-10 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
            </div>
            <h2 class="text-xl font-bold mb-2">Aucun coffre</h2>
            <p class="text-slate-400 mb-6">Créez votre premier coffre pour organiser vos mots de passe.</p>
            <button onclick="openCreateModal()" class="btn btn-primary">+ Créer un coffre</button>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            {% for vault in active_vaults %}
                {% set color       = palette[loop.index0 % palette|length] %}
                {% set entry_count = vault.passwordEntries|length %}
                <div class="glass-card rounded-2xl p-6 flex flex-col space-y-4 hover:border-white/20 transition group">

                    {# Card header #}
                    <div class="flex items-start justify-between">
                        <div class="flex items-center space-x-3">
                            <div class="h-12 w-12 rounded-xl {{ color.bg }} flex items-center justify-center shrink-0">
                                <svg class="h-6 w-6 {{ color.text }}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <h3 class="font-bold text-lg leading-tight truncate">{{ vault.name }}</h3>
                                <span class="text-xs {{ color.text }} font-medium">
                                    {{ entry_count }} {{ entry_count == 1 ? 'entrée' : 'entrées' }}
                                </span>
                            </div>
                        </div>

                        {# Action buttons — visible on hover #}
                        <div class="flex items-center space-x-1 opacity-0 group-hover:opacity-100 transition">
                            <button
                                type="button"
                                onclick="openEditModal(this)"
                                data-id="{{ vault.id }}"
                                data-name="{{ vault.name|e('html_attr') }}"
                                data-description="{{ vault.description|default('')|e('html_attr') }}"
                                data-csrf="{{ csrf_token('vault_edit_' ~ vault.id) }}"
                                class="p-1.5 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition"
                                title="Renommer"
                            >
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </button>
                            <form method="post" action="{{ path('app_vault_archive', {id: vault.id}) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('vault_archive_' ~ vault.id) }}">
                                <button type="submit"
                                    class="p-1.5 rounded-lg text-slate-400 hover:text-amber-400 hover:bg-white/5 transition"
                                    title="Archiver ce coffre"
                                    onclick="return confirm('Archiver ce coffre ?')"
                                >
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    {# Description #}
                    {% if vault.description %}
                        <p class="text-sm text-slate-400 line-clamp-2 flex-1">{{ vault.description }}</p>
                    {% else %}
                        <p class="text-sm text-slate-600 italic flex-1">Aucune description.</p>
                    {% endif %}

                    {# Card footer #}
                    <div class="pt-3 border-t border-white/5 flex items-center justify-between">
                        <span class="text-xs text-slate-500">Créé le {{ vault.createdAt|date('d/m/Y') }}</span>
                        <span class="text-xs px-2 py-0.5 rounded-full bg-green-500/10 text-green-400 font-medium">Actif</span>
                    </div>
                </div>
            {% endfor %}

            {# Bouton rapide pour créer un nouveau coffre #}
            <button
                onclick="openCreateModal()"
                class="glass-card rounded-2xl p-6 flex flex-col items-center justify-center space-y-3 border-dashed hover:border-indigo-500/40 hover:bg-indigo-500/5 transition text-slate-500 hover:text-indigo-400 min-h-[180px]"
            >
                <div class="h-12 w-12 rounded-xl bg-white/5 flex items-center justify-center">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                    </svg>
                </div>
                <span class="text-sm font-medium">Nouveau coffre</span>
            </button>
        </div>

        {# ---- Vaults archivés ---- #}
        {% if archived_vaults is not empty %}
            <div>
                <h2 class="text-base font-semibold text-slate-400 mb-4 flex items-center space-x-2">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                    </svg>
                    <span>Archivés ({{ archived_vaults|length }})</span>
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                    {% for vault in archived_vaults %}
                        {% set entry_count = vault.passwordEntries|length %}
                        <div class="glass-card rounded-2xl p-5 flex items-center justify-between opacity-50 hover:opacity-75 transition">
                            <div class="flex items-center space-x-3 min-w-0">
                                <div class="h-9 w-9 rounded-xl bg-slate-700/50 flex items-center justify-center shrink-0">
                                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <p class="font-medium truncate">{{ vault.name }}</p>
                                    <p class="text-xs text-slate-500">{{ entry_count }} {{ entry_count == 1 ? 'entrée' : 'entrées' }}</p>
                                </div>
                            </div>
                            <form method="post" action="{{ path('app_vault_archive', {id: vault.id}) }}" class="ml-4 shrink-0">
                                <input type="hidden" name="_token" value="{{ csrf_token('vault_archive_' ~ vault.id) }}">
                                <button type="submit" class="text-xs text-indigo-400 hover:text-indigo-300 transition px-3 py-1.5 rounded-lg hover:bg-white/5 font-medium">
                                    Restaurer
                                </button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    {% endif %}
</div>

{# ============================= MODAL CRÉER ============================= #}
<div id="create-modal" class="{{ open_modal ? '' : 'hidden' }} fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeCreateModal()"></div>
    <div class="relative z-10 w-full max-w-md glass-card rounded-2xl overflow-hidden shadow-2xl">

        <div class="flex items-center justify-between px-6 py-5 border-b border-white/10">
            <div class="flex items-center space-x-3">
                <div class="h-9 w-9 rounded-xl bg-indigo-500/20 flex items-center justify-center">
                    <svg class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                </div>
                <h2 class="text-lg font-bold">Nouveau coffre</h2>
            </div>
            <button onclick="closeCreateModal()" class="text-slate-400 hover:text-white transition rounded-lg p-1 hover:bg-white/5">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        {{ form_start(create_form, {attr: {novalidate: 'novalidate'}}) }}
        <div class="px-6 py-5 space-y-4">
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
                    Nom <span class="text-red-400">*</span>
                </label>
                {{ form_widget(create_form.name) }}
                {{ form_errors(create_form.name) }}
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
                    Description
                </label>
                {{ form_widget(create_form.description) }}
            </div>
        </div>
        <div class="px-6 py-4 border-t border-white/10 flex justify-end space-x-3">
            <button type="button" onclick="closeCreateModal()" class="btn btn-ghost px-5">Annuler</button>
            <button type="submit" class="btn btn-primary flex items-center space-x-2">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>Créer</span>
            </button>
        </div>
        {{ form_end(create_form) }}
    </div>
</div>

{# ============================= MODAL MODIFIER ============================= #}
<div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeEditModal()"></div>
    <div class="relative z-10 w-full max-w-md glass-card rounded-2xl overflow-hidden shadow-2xl">

        <div class="flex items-center justify-between px-6 py-5 border-b border-white/10">
            <div class="flex items-center space-x-3">
                <div class="h-9 w-9 rounded-xl bg-amber-500/20 flex items-center justify-center">
                    <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                </div>
                <h2 class="text-lg font-bold">Modifier le coffre</h2>
            </div>
            <button onclick="closeEditModal()" class="text-slate-400 hover:text-white transition rounded-lg p-1 hover:bg-white/5">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form id="edit-form" method="post" novalidate>
            <input type="hidden" id="edit-csrf" name="_token" value="">
            <div class="px-6 py-5 space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
                        Nom <span class="text-red-400">*</span>
                    </label>
                    <input
                        type="text" id="edit-name" name="name" required
                        class="w-full bg-slate-800/50 border border-white/10 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition text-sm"
                        placeholder="Nom du coffre..."
                    >
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5">
                        Description
                    </label>
                    <textarea
                        id="edit-description" name="description" rows="3"
                        class="w-full bg-slate-800/50 border border-white/10 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition text-sm"
                        placeholder="Description optionnelle..."
                    ></textarea>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-white/10 flex justify-end space-x-3">
                <button type="button" onclick="closeEditModal()" class="btn btn-ghost px-5">Annuler</button>
                <button type="submit" class="btn btn-primary flex items-center space-x-2" style="background:linear-gradient(135deg,#d97706,#b45309)">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span>Mettre à jour</span>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function openCreateModal() { document.getElementById('create-modal').classList.remove('hidden'); }
function closeCreateModal() { document.getElementById('create-modal').classList.add('hidden'); }

function openEditModal(btn) {
    document.getElementById('edit-form').action = `/vaults/${btn.dataset.id}/edit`;
    document.getElementById('edit-name').value        = btn.dataset.name ?? '';
    document.getElementById('edit-description').value = btn.dataset.description ?? '';
    document.getElementById('edit-csrf').value         = btn.dataset.csrf ?? '';
    document.getElementById('edit-modal').classList.remove('hidden');
    document.getElementById('edit-name').focus();
}
function closeEditModal() { document.getElementById('edit-modal').classList.add('hidden'); }

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeCreateModal(); closeEditModal(); }
});
</script>

{% endblock body_connected %}
