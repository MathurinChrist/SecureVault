{% extends 'base.html.twig' %}

{% block title %}Mes Coffres - SecureVault{% endblock %}

{% block body_connected %}

{% set palette = [
    {bg: 'bg-brand/10', text: 'text-brand-mid'},
    {bg: 'bg-emerald-50',   text: 'text-emerald-600'},
    {bg: 'bg-amber-50',     text: 'text-amber-600'},
    {bg: 'bg-rose-50',      text: 'text-rose-600'},
    {bg: 'bg-sky-50',       text: 'text-sky-600'},
    {bg: 'bg-teal-50',      text: 'text-teal-600'},
    {bg: 'bg-violet-50',    text: 'text-violet-600'},
] %}

<!-- Header -->
<div class="mb-6">
    <div class="flex items-start justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Mes Coffres</h1>
            <p class="text-gray-500 mt-1 text-sm">Organisez vos mots de passe par catégorie.</p>
        </div>
        <button onclick="openCreateModal()" class="flex items-center space-x-2 bg-brand hover:bg-brand-light text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <span>Nouveau coffre</span>
        </button>
    </div>
</div>

<!-- Stats -->
{% set active_vaults   = vaults|filter(v => not v.archived) %}
{% set archived_vaults = vaults|filter(v => v.archived) %}
{% set total_entries   = 0 %}
{% for v in vaults %}{% set total_entries = total_entries + v.passwordEntries|length %}{% endfor %}

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-gray-500 text-sm font-medium">Coffres actifs</p>
        <p class="text-3xl font-bold text-gray-900 mt-1">{{ active_vaults|length }}</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-gray-500 text-sm font-medium">Coffres archivés</p>
        <p class="text-3xl font-bold text-gray-400 mt-1">{{ archived_vaults|length }}</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
        <p class="text-gray-500 text-sm font-medium">Total mots de passe</p>
        <p class="text-3xl font-bold text-brand-mid mt-1">{{ total_entries }}</p>
    </div>
</div>

<!-- Vault grid -->
{% if vaults is empty %}
<div class="bg-white rounded-xl border border-gray-200 p-16 text-center">
    <div class="h-16 w-16 mx-auto bg-brand/10 rounded-2xl flex items-center justify-center mb-4">
        <svg class="h-8 w-8 text-brand-mid" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
    </div>
    <h2 class="text-lg font-bold text-gray-900 mb-1">Aucun coffre</h2>
    <p class="text-gray-500 text-sm mb-5">Créez votre premier coffre pour organiser vos mots de passe.</p>
    <button onclick="openCreateModal()" class="btn btn-primary text-sm">+ Créer un coffre</button>
</div>
{% else %}
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
    {% for vault in active_vaults %}
    {% set color = palette[loop.index0 % palette|length] %}
    {% set entry_count = vault.passwordEntries|length %}
    <div class="bg-white rounded-xl border border-gray-200 p-5 flex flex-col space-y-4 hover:shadow-md transition cursor-pointer group"
         onclick="window.location.href='{{ path('app_vault_show', {id: vault.id}) }}'">
        <div class="flex items-start justify-between">
            <div class="flex items-center space-x-3 min-w-0">
                <div class="h-11 w-11 rounded-xl {{ color.bg }} flex items-center justify-center shrink-0">
                    <svg class="h-5 w-5 {{ color.text }}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                </div>
                <div class="min-w-0">
                    <h3 class="font-bold text-gray-900 leading-tight truncate">{{ vault.name }}</h3>
                    <span class="text-xs {{ color.text }} font-medium">{{ entry_count }} {{ entry_count == 1 ? 'entrée' : 'entrées' }}</span>
                </div>
            </div>
            <span class="text-xs px-2 py-0.5 rounded-full bg-green-50 text-green-600 font-medium shrink-0">Actif</span>
        </div>
        {% if vault.description %}
        <p class="text-sm text-gray-500 line-clamp-2 flex-1">{{ vault.description }}</p>
        {% else %}
        <p class="text-sm text-gray-300 italic flex-1">Aucune description.</p>
        {% endif %}
        <div class="pt-3 border-t border-gray-100 flex items-center justify-between">
            <span class="text-xs text-gray-400">Créé le {{ vault.createdAt|date('d/m/Y') }}</span>
            <span class="text-xs text-brand-mid font-medium opacity-0 group-hover:opacity-100 transition">Ouvrir →</span>
        </div>
    </div>
    {% endfor %}

    <!-- Add vault button -->
    <button onclick="openCreateModal()"
        class="bg-white rounded-xl border-2 border-dashed border-gray-200 p-5 flex flex-col items-center justify-center space-y-3 hover:border-brand/40 hover:bg-brand/5 transition text-gray-400 hover:text-brand-mid min-h-[160px]">
        <div class="h-11 w-11 rounded-xl bg-gray-100 flex items-center justify-center">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
        </div>
        <span class="text-sm font-medium">Nouveau coffre</span>
    </button>
</div>

<!-- Archived -->
{% if archived_vaults is not empty %}
<div class="mt-8">
    <h2 class="text-sm font-semibold text-gray-500 mb-3 flex items-center space-x-2 uppercase tracking-wider">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
        <span>Archivés ({{ archived_vaults|length }})</span>
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
        {% for vault in archived_vaults %}
        {% set entry_count = vault.passwordEntries|length %}
        <div class="bg-white rounded-xl border border-gray-200 p-4 flex items-center justify-between opacity-50 hover:opacity-75 transition">
            <div class="flex items-center space-x-3 min-w-0">
                <div class="h-9 w-9 rounded-lg bg-gray-100 flex items-center justify-center shrink-0">
                    <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                </div>
                <div class="min-w-0">
                    <p class="font-medium text-gray-700 truncate text-sm">{{ vault.name }}</p>
                    <p class="text-xs text-gray-400">{{ entry_count }} {{ entry_count == 1 ? 'entrée' : 'entrées' }}</p>
                </div>
            </div>
            <form method="post" action="{{ path('app_vault_archive', {id: vault.id}) }}" class="ml-4 shrink-0">
                <input type="hidden" name="_token" value="{{ csrf_token('vault_archive_' ~ vault.id) }}">
                <button type="submit" class="text-xs text-brand-mid hover:text-brand font-medium px-3 py-1.5 rounded-lg hover:bg-brand/10 transition">Restaurer</button>
            </form>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}
{% endif %}

{# ===== MODAL CRÉER ===== #}
<div id="create-modal" class="{{ open_modal ? '' : 'hidden' }} fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeCreateModal()"></div>
    <div class="relative z-10 w-full max-w-md bg-white rounded-2xl overflow-hidden shadow-2xl">
        <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
            <div class="flex items-center space-x-3">
                <div class="h-10 w-10 rounded-xl bg-brand/10 flex items-center justify-center">
                    <svg class="h-5 w-5 text-brand-mid" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                </div>
                <div>
                    <h2 class="text-base font-bold text-gray-900">Nouveau coffre</h2>
                    <p class="text-xs text-gray-500">Créer un nouveau coffre sécurisé</p>
                </div>
            </div>
            <button onclick="closeCreateModal()" class="text-gray-400 hover:text-gray-700 transition rounded-lg p-1.5 hover:bg-gray-100">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        {{ form_start(create_form) }}
        <div class="px-6 py-5 space-y-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nom <span class="text-red-500">*</span></label>
                {{ form_widget(create_form.name, {'attr': {'class': 'w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition text-sm', 'placeholder': 'Nom du coffre...'}}) }}
                {{ form_errors(create_form.name) }}
            </div>
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Description</label>
                {{ form_widget(create_form.description, {'attr': {'class': 'w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition text-sm', 'placeholder': 'Description optionnelle...'}}) }}
            </div>
        </div>
        <div class="px-6 py-4 border-t border-gray-100 flex justify-end space-x-3">
            <button type="button" onclick="closeCreateModal()" class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition">Annuler</button>
            <button type="submit" class="flex items-center space-x-2 bg-brand hover:bg-brand-light text-white text-sm font-semibold px-5 py-2 rounded-lg transition">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span>Créer</span>
            </button>
        </div>
        {{ form_end(create_form) }}
    </div>
</div>

{# ===== MODAL MODIFIER ===== #}
<div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeEditModal()"></div>
    <div class="relative z-10 w-full max-w-md bg-white rounded-2xl overflow-hidden shadow-2xl">
        <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
            <div class="flex items-center space-x-3">
                <div class="h-10 w-10 rounded-xl bg-amber-50 flex items-center justify-center">
                    <svg class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                </div>
                <div>
                    <h2 class="text-base font-bold text-gray-900">Modifier le coffre</h2>
                    <p class="text-xs text-gray-500">Mettre à jour les informations</p>
                </div>
            </div>
            <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-700 transition rounded-lg p-1.5 hover:bg-gray-100">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form id="edit-form" method="post">
            <input type="hidden" id="edit-csrf" name="_token" value="">
            <div class="px-6 py-5 space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nom <span class="text-red-500">*</span></label>
                    <input type="text" id="edit-name" name="name" required placeholder="Nom du coffre..."
                        class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition text-sm">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Description</label>
                    <textarea id="edit-description" name="description" rows="3" placeholder="Description optionnelle..."
                        class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition text-sm"></textarea>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 flex justify-end space-x-3">
                <button type="button" onclick="closeEditModal()" class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition">Annuler</button>
                <button type="submit" class="flex items-center space-x-2 text-white text-sm font-semibold px-5 py-2 rounded-lg transition" style="background:linear-gradient(135deg,#d97706,#b45309)">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Mettre à jour</span>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function openCreateModal()  { document.getElementById('create-modal').classList.remove('hidden'); }
function closeCreateModal() { document.getElementById('create-modal').classList.add('hidden'); }
function openEditModal(btn) {
    document.getElementById('edit-form').action = `/vaults/${btn.dataset.id}/edit`;
    document.getElementById('edit-name').value        = btn.dataset.name ?? '';
    document.getElementById('edit-description').value = btn.dataset.description ?? '';
    document.getElementById('edit-csrf').value        = btn.dataset.csrf ?? '';
    document.getElementById('edit-modal').classList.remove('hidden');
    document.getElementById('edit-name').focus();
}
function closeEditModal() { document.getElementById('edit-modal').classList.add('hidden'); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeCreateModal(); closeEditModal(); } });
</script>
{% endblock body_connected %}
