{% extends 'base.html.twig' %}

{% block title %}Partages — {{ vault.name }} - SecureVault{% endblock %}

{% block body_connected %}
<div class="space-y-8">

    {# ---- Header ---- #}
    <div class="flex items-center space-x-4">
        <a href="{{ path('app_vault_show', {id: vault.id}) }}" class="p-2 rounded-xl text-gray-400 hover:text-gray-900 hover:bg-gray-100 transition" title="Retour au coffre">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Partages — {{ vault.name }}</h1>
            <p class="text-gray-500 text-sm mt-0.5">Gérez les accès partagés à ce coffre.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

        {# ---- Invite form ---- #}
        <div class="lg:col-span-2">
            <div class="dash-card rounded-2xl overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-100 flex items-center space-x-3">
                    <div class="h-8 w-8 rounded-xl bg-brand/10 flex items-center justify-center">
                        <svg class="h-4 w-4 text-brand-mid" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                        </svg>
                    </div>
                    <h2 class="font-bold text-gray-900">Inviter un utilisateur</h2>
                </div>
                <form method="post" action="{{ path('app_vault_share_new', {id: vault.id}) }}" class="px-6 py-5 space-y-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('vault_share_' ~ vault.id) }}">

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                            Adresse email <span class="text-red-500">*</span>
                        </label>
                        <input
                            type="email" name="email" required
                            class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition text-sm"
                            placeholder="utilisateur@exemple.com"
                        >
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                            Niveau d'accès <span class="text-red-500">*</span>
                        </label>
                        <select name="permission" class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition text-sm">
                            {% for perm in permissions %}
                                <option value="{{ perm.code }}">{{ perm.name }} — {{ perm.description }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="pt-2">
                        <button type="submit" class="w-full btn btn-primary flex items-center justify-center space-x-2">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                            </svg>
                            <span>Envoyer l'invitation</span>
                        </button>
                    </div>
                </form>

                {# Access level legend #}
                <div class="px-6 pb-5 space-y-2">
                    <p class="text-xs text-gray-500 uppercase font-semibold tracking-wider mb-2">Niveaux d'accès</p>
                    <div class="flex items-center space-x-2 text-xs text-gray-500">
                        <span class="px-2 py-0.5 rounded-full bg-sky-100 text-sky-700 font-medium">Lecture</span>
                        <span>Consultation uniquement</span>
                    </div>
                    <div class="flex items-center space-x-2 text-xs text-gray-500">
                        <span class="px-2 py-0.5 rounded-full bg-brand/10 text-brand-mid font-medium">Écriture</span>
                        <span>Lecture + ajout / modification</span>
                    </div>
                    <div class="flex items-center space-x-2 text-xs text-gray-500">
                        <span class="px-2 py-0.5 rounded-full bg-purple-100 text-purple-700 font-medium">Administration</span>
                        <span>Accès complet + partage</span>
                    </div>
                </div>
            </div>
        </div>

        {# ---- Current shares ---- #}
        <div class="lg:col-span-3">
            <div class="dash-card rounded-2xl overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-100">
                    <h2 class="font-bold text-gray-900">Accès actuels ({{ shares|length }})</h2>
                </div>

                {% if shares is empty %}
                    <div class="px-6 py-12 text-center">
                        <p class="text-gray-500 text-sm italic">Ce coffre n'est partagé avec personne.</p>
                    </div>
                {% else %}
                    <div class="divide-y divide-gray-100">
                        {% for share in shares %}
                            {% set permCode = share.permission.code %}
                            {% set permStyle = permCode == 'ADMIN' ? 'bg-purple-100 text-purple-700' : (permCode == 'WRITE' ? 'bg-brand/10 text-brand-mid' : 'bg-sky-100 text-sky-700') %}
                            <div class="px-6 py-4 flex items-center justify-between">
                                <div class="flex items-center space-x-3 min-w-0">
                                    <div class="h-9 w-9 rounded-full bg-brand/10 text-brand-mid flex items-center justify-center font-bold text-sm shrink-0">
                                        {{ share.recipient.email|first|upper }}
                                    </div>
                                    <div class="min-w-0">
                                        <p class="font-medium text-sm truncate text-gray-900">{{ share.recipient.email }}</p>
                                        <p class="text-xs text-gray-500 mt-0.5">
                                            {% if share.accepted %}
                                                Accepté {{ share.acceptedAt ? 'le ' ~ share.acceptedAt|date('d/m/Y') : '' }}
                                            {% else %}
                                                <span class="text-amber-600">En attente</span> · Envoyé {{ share.sharedAt|date('d/m/Y') }}
                                            {% endif %}
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-3 shrink-0 ml-4">
                                    <span class="px-2 py-0.5 text-xs rounded-full font-medium {{ permStyle }}">{{ share.permission.name }}</span>
                                    <form method="post" action="{{ path('app_share_revoke', {id: share.id}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('share_revoke_' ~ share.id) }}">
                                        <button type="submit"
                                            class="text-xs text-gray-500 hover:text-red-500 transition px-2 py-1 rounded hover:bg-gray-100"
                                            onclick="return confirm('Révoquer l\'accès de {{ share.recipient.email|e('js') }} ?')"
                                        >Révoquer</button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock body_connected %}
