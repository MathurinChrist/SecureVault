{% extends 'admin/layout.html.twig' %}

{% block title %}Message de {{ message.name }}{% endblock %}
{% block page_label %}Message de contact{% endblock %}

{% block content %}

<div class="mb-5">
    <a href="{{ path('admin_contacts') }}" class="inline-flex items-center gap-2 text-[13.5px] font-semibold text-ink-muted hover:text-ink transition">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Tous les messages
    </a>
</div>

<div class="max-w-2xl">
    <div class="bg-white rounded-2xl border border-line overflow-hidden">

        {# Header #}
        <div class="p-6 border-b border-line">
            <div class="flex items-start justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="h-12 w-12 rounded-full bg-brand/10 flex items-center justify-center text-brand font-extrabold text-[16px] flex-shrink-0">
                        {{ message.name|first|upper }}
                    </div>
                    <div>
                        <h1 class="text-[18px] font-extrabold text-ink">{{ message.name }}</h1>
                        <a href="mailto:{{ message.email }}" class="text-[14px] text-brand-mid font-semibold hover:underline">{{ message.email }}</a>
                    </div>
                </div>
                <div class="text-right flex-shrink-0">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[12px] font-bold {{ message.isRead ? 'bg-brand/10 text-brand-mid' : 'bg-warn/10 text-warn' }}">
                        <span class="h-1.5 w-1.5 rounded-full {{ message.isRead ? 'bg-brand-mid' : 'bg-warn' }}"></span>
                        {{ message.isRead ? 'Lu' : 'Non lu' }}
                    </span>
                    <p class="text-[12px] text-ink-muted mt-1.5">{{ message.createdAt|date('d/m/Y à H:i') }}</p>
                </div>
            </div>
        </div>

        {# Subject #}
        <div class="px-6 py-4 border-b border-line bg-surface">
            <p class="text-[11px] font-bold text-ink-muted uppercase tracking-wider mb-1">Sujet</p>
            <p class="text-[15px] font-bold text-ink">{{ message.subject }}</p>
        </div>

        {# Message body #}
        <div class="p-6">
            <p class="text-[11px] font-bold text-ink-muted uppercase tracking-wider mb-3">Message</p>
            <div class="bg-surface border border-line rounded-xl p-5">
                <p class="text-[14.5px] text-ink leading-relaxed whitespace-pre-wrap">{{ message.message }}</p>
            </div>
        </div>

        {# Reply action #}
        <div class="px-6 pb-6">
            <a href="mailto:{{ message.email }}?subject=Re: {{ message.subject|url_encode }}"
               class="inline-flex items-center gap-2 bg-brand hover:bg-brand-light text-white font-bold text-[14px] px-6 py-3 rounded-full transition">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
                Répondre par e-mail
            </a>
        </div>
    </div>
</div>

{% endblock %}
