{% extends 'admin/layout.html.twig' %}

{% block title %}Utilisateurs{% endblock %}
{% block page_label %}Utilisateurs{% endblock %}

{% block content %}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-[22px] font-extrabold text-ink tracking-tight">Utilisateurs</h1>
        <p class="text-[14px] text-ink-muted mt-0.5">{{ users|length }} compte{{ users|length != 1 ? 's' }} enregistré{{ users|length != 1 ? 's' }}</p>
    </div>
</div>

<div class="bg-white rounded-2xl border border-line overflow-hidden">
    {% if users is empty %}
        <p class="text-center text-ink-muted py-16 text-[14px]">Aucun utilisateur.</p>
    {% else %}
        <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-line">
                    <th class="text-left px-6 py-3.5 text-[11px] font-bold text-ink-muted uppercase tracking-wider">Utilisateur</th>
                    <th class="text-left px-6 py-3.5 text-[11px] font-bold text-ink-muted uppercase tracking-wider hidden sm:table-cell">Rôles</th>
                    <th class="text-left px-6 py-3.5 text-[11px] font-bold text-ink-muted uppercase tracking-wider hidden md:table-cell">Statut</th>
                    <th class="text-left px-6 py-3.5 text-[11px] font-bold text-ink-muted uppercase tracking-wider hidden lg:table-cell">Inscription</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr class="border-b border-line last:border-0 hover:bg-surface transition">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="h-9 w-9 rounded-full bg-brand/10 flex items-center justify-center text-brand text-[12px] font-extrabold flex-shrink-0">
                                {% if user.firstName and user.lastName %}
                                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                {% else %}
                                    {{ user.email|first|upper }}
                                {% endif %}
                            </div>
                            <div class="min-w-0">
                                <p class="text-[13.5px] font-bold text-ink truncate">
                                    {% if user.firstName or user.lastName %}
                                        {{ user.firstName }} {{ user.lastName }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </p>
                                <p class="text-[12px] text-ink-muted truncate">{{ user.email }}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 hidden sm:table-cell">
                        <div class="flex flex-wrap gap-1">
                        {% for role in user.roles %}
                            {% if role != 'ROLE_USER' %}
                            <span class="text-[11px] font-bold px-2.5 py-1 rounded-full {{ role == 'ROLE_ADMIN' ? 'bg-brand/10 text-brand-mid' : 'bg-surface text-ink-muted' }}">
                                {{ role|replace({'ROLE_': ''}) }}
                            </span>
                            {% endif %}
                        {% endfor %}
                        {% if 'ROLE_ADMIN' not in user.roles %}
                            <span class="text-[11px] font-bold px-2.5 py-1 rounded-full bg-surface text-ink-muted">USER</span>
                        {% endif %}
                        </div>
                    </td>
                    <td class="px-6 py-4 hidden md:table-cell">
                        {% if user.isVerified is defined %}
                            <span class="inline-flex items-center gap-1.5 text-[12px] font-semibold {{ user.isVerified ? 'text-brand-mid' : 'text-warn' }}">
                                <span class="h-1.5 w-1.5 rounded-full {{ user.isVerified ? 'bg-brand-mid' : 'bg-warn' }}"></span>
                                {{ user.isVerified ? 'Vérifié' : 'Non vérifié' }}
                            </span>
                        {% else %}
                            <span class="text-[12px] text-ink-muted">—</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 text-[13px] text-ink-muted hidden lg:table-cell">
                        {% if user.createdAt is defined and user.createdAt %}
                            {{ user.createdAt|date('d/m/Y') }}
                        {% else %}
                            —
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        </div>
    {% endif %}
</div>

{% endblock %}
