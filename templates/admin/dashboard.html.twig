{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_title %}Tableau de bord{% endblock %}

{% block main %}

{# ── Stat cards ── #}
<div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:1rem;margin-bottom:1.5rem;">

    <div style="background:#fff;border-radius:16px;border:1px solid #e0e4e8;padding:1.25rem;">
        <div style="height:40px;width:40px;border-radius:12px;background:rgba(20,47,50,.1);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
            <svg style="height:20px;width:20px;color:#2f7d5b;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        </div>
        <p style="font-size:30px;font-weight:800;color:#181d22;letter-spacing:-0.02em;line-height:1;">{{ stats.users }}</p>
        <p style="font-size:13px;color:#6a7480;margin-top:0.375rem;">Utilisateurs</p>
    </div>

    <div style="background:#fff;border-radius:16px;border:1px solid #e0e4e8;padding:1.25rem;">
        <div style="height:40px;width:40px;border-radius:12px;background:rgba(20,47,50,.1);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
            <svg style="height:20px;width:20px;color:#2f7d5b;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        </div>
        <p style="font-size:30px;font-weight:800;color:#181d22;letter-spacing:-0.02em;line-height:1;">{{ stats.vaults }}</p>
        <p style="font-size:13px;color:#6a7480;margin-top:0.375rem;">Coffres</p>
    </div>

    <div style="background:#fff;border-radius:16px;border:1px solid #e0e4e8;padding:1.25rem;">
        <div style="height:40px;width:40px;border-radius:12px;background:{{ stats.failed_logins > 0 ? 'rgba(196,69,58,.1)' : 'rgba(20,47,50,.1)' }};display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
            <svg style="height:20px;width:20px;color:{{ stats.failed_logins > 0 ? '#c4453a' : '#2f7d5b' }};" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
        </div>
        <p style="font-size:30px;font-weight:800;letter-spacing:-0.02em;line-height:1;color:{{ stats.failed_logins > 0 ? '#c4453a' : '#181d22' }};">{{ stats.failed_logins }}</p>
        <p style="font-size:13px;color:#6a7480;margin-top:0.375rem;">Échecs connexion (24h)</p>
    </div>

    <div style="background:#fff;border-radius:16px;border:1px solid #e0e4e8;padding:1.25rem;">
        <div style="height:40px;width:40px;border-radius:12px;background:{{ stats.unread_contacts > 0 ? 'rgba(183,121,31,.1)' : 'rgba(20,47,50,.1)' }};display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
            <svg style="height:20px;width:20px;color:{{ stats.unread_contacts > 0 ? '#b7791f' : '#2f7d5b' }};" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <p style="font-size:30px;font-weight:800;letter-spacing:-0.02em;line-height:1;color:{{ stats.unread_contacts > 0 ? '#b7791f' : '#181d22' }};">{{ stats.unread_contacts }}</p>
        <p style="font-size:13px;color:#6a7480;margin-top:0.375rem;">Messages non lus</p>
    </div>
</div>

{# ── Main grid ── #}
<div style="display:grid;grid-template-columns:1fr;gap:1.25rem;">

    {# Recent contacts #}
    <div style="background:#fff;border-radius:16px;border:1px solid #e0e4e8;padding:1.5rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
            <h2 style="font-weight:800;color:#181d22;font-size:16px;margin:0;">Messages récents</h2>
            <a href="{{ path('easyadmin_dashboard_contact_message_index') }}" style="font-size:13px;font-weight:600;color:#6a7480;border:1px solid #e0e4e8;padding:0.375rem 0.75rem;border-radius:9999px;text-decoration:none;">
                Voir tout →
            </a>
        </div>
        {% if recent_contacts is empty %}
            <p style="font-size:14px;color:#6a7480;text-align:center;padding:2.5rem 0;">Aucun message non lu.</p>
        {% else %}
            <div>
            {% for msg in recent_contacts %}
                <a href="{{ path('easyadmin_dashboard_contact_message_detail', {entityId: msg.id}) }}"
                   style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.875rem;border-radius:12px;border:1px solid transparent;text-decoration:none;">
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
                            <p style="font-size:13.5px;font-weight:700;color:#181d22;margin:0;">{{ msg.name }}</p>
                            <span style="font-size:11px;color:#6a7480;white-space:nowrap;">{{ msg.createdAt|date('d/m H:i') }}</span>
                        </div>
                        <p style="font-size:12.5px;color:#6a7480;margin:0.125rem 0 0;">{{ msg.subject }}</p>
                    </div>
                </a>
            {% endfor %}
            </div>
        {% endif %}
    </div>

    {# Recent activity #}
    <div style="background:#fff;border-radius:16px;border:1px solid #e0e4e8;padding:1.5rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
            <h2 style="font-weight:800;color:#181d22;font-size:16px;margin:0;">Activité récente</h2>
            <span style="font-size:12px;color:#6a7480;font-weight:600;background:#f4f6f7;border:1px solid #e0e4e8;padding:0.375rem 0.75rem;border-radius:9999px;">{{ stats.activity_today }} actions aujourd'hui</span>
        </div>
        {% if recent_activity is empty %}
            <p style="font-size:14px;color:#6a7480;text-align:center;padding:2.5rem 0;">Aucune activité récente.</p>
        {% else %}
            <div>
            {% for log in recent_activity %}
                <div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;padding:0.625rem 0.75rem;border-radius:12px;">
                    <div style="display:flex;align-items:center;gap:0.75rem;min-width:0;">
                        <div style="height:8px;width:8px;border-radius:9999px;background:#2f7d5b;flex-shrink:0;"></div>
                        <div style="min-width:0;">
                            <span style="font-size:13.5px;font-weight:600;color:#181d22;display:block;">{{ log.action }}</span>
                            {% if log.user %}
                                <span style="font-size:11.5px;color:#6a7480;">{{ log.user.email }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <span style="font-size:11px;color:#6a7480;white-space:nowrap;flex-shrink:0;">{{ log.createdAt|date('d/m H:i') }}</span>
                </div>
            {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
