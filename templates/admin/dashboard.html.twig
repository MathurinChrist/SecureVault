{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Tableau de bord{% endblock %}

{% block main %}
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fa fa-users fa-lg text-primary"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">{{ stats.users }}</div>
                    <div class="text-muted small">Utilisateurs</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fa fa-lock fa-lg text-success"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">{{ stats.vaults }}</div>
                    <div class="text-muted small">Coffres</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="fa fa-bell fa-lg text-warning"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">{{ stats.unread_alerts }}</div>
                    <div class="text-muted small">Alertes non lues</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="fa fa-shield fa-lg text-danger"></i>
                </div>
                <div>
                    <div class="fs-4 fw-bold">{{ stats.failed_logins }}</div>
                    <div class="text-muted small">Échecs connexion (24h)</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fa fa-bell me-2 text-warning"></i>Dernières alertes
            </div>
            <div class="card-body p-0">
                {% if recent_alerts is empty %}
                    <p class="text-muted p-3 mb-0">Aucune alerte.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for alert in recent_alerts %}
                            <li class="list-group-item d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge bg-{% if alert.type == 'danger' %}danger{% elseif alert.type == 'warning' %}warning text-dark{% elseif alert.type == 'success' %}success{% else %}info{% endif %} me-2">
                                        {{ alert.type|capitalize }}
                                    </span>
                                    {{ alert.title }}
                                    {% if not alert.isRead %}
                                        <span class="badge bg-secondary ms-1">Non lue</span>
                                    {% endif %}
                                </div>
                                <small class="text-muted text-nowrap ms-2">{{ alert.createdAt|date('d/m H:i') }}</small>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
            <div class="card-footer bg-transparent">
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\AlertCrudController') }}" class="btn btn-sm btn-outline-secondary">
                    Voir toutes les alertes
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fa fa-list me-2 text-info"></i>Activité récente
                <small class="text-muted fw-normal ms-2">({{ stats.activity_today }} actions aujourd'hui)</small>
            </div>
            <div class="card-body p-0">
                {% if recent_activity is empty %}
                    <p class="text-muted p-3 mb-0">Aucune activité récente.</p>
                {% else %}
                    <ul class="list-group list-group-flush">
                        {% for log in recent_activity %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-medium">{{ log.action }}</span>
                                    {% if log.user %}
                                        <small class="text-muted ms-1">— {{ log.user.email }}</small>
                                    {% endif %}
                                </div>
                                <small class="text-muted text-nowrap ms-2">{{ log.createdAt|date('d/m H:i') }}</small>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
            <div class="card-footer bg-transparent">
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ActivityLogCrudController') }}" class="btn btn-sm btn-outline-secondary">
                    Voir tous les journaux
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
