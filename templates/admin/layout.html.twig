<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Admin{% endblock %} — SecureVault</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand:   { DEFAULT:'#142F32', light:'#1c3e42', mid:'#2f7d5b' },
                        accent:  { DEFAULT:'#E3FFCC', dark:'#d2f7b3' },
                        ink:     { DEFAULT:'#181d22', soft:'#3c454c', muted:'#6a7480' },
                        canvas:  '#e9ecef',
                        surface: '#f4f6f7',
                        line:    '#e0e4e8',
                        danger:  '#c4453a',
                        warn:    '#b7791f',
                    }
                }
            }
        }
    </script>
    <style type="text/tailwindcss">
        @layer base {
            body { font-family:'Manrope',system-ui,sans-serif; @apply antialiased; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="min-h-screen flex bg-canvas text-ink">

{%- set _route = app.request.get('_route') -%}
{%- set _li = 'flex items-center gap-3 px-3 py-2.5 rounded-xl text-[13.5px] font-semibold transition-all duration-150 mb-0.5' -%}
{%- set _active   = 'bg-accent text-brand' -%}
{%- set _inactive = 'text-white/60 hover:text-white hover:bg-white/[.06]' -%}

{# ── Sidebar ── #}
<aside id="svSidebar" class="w-64 bg-brand flex flex-col fixed inset-y-0 left-0 z-[60] -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out">

    <div class="px-5 py-5 flex items-center gap-2.5 border-b border-white/[.08]">
        <svg class="w-8 h-8 flex-none" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="13" stroke="#E3FFCC" stroke-width="5" stroke-dasharray="56 26" stroke-linecap="round"/><circle cx="16" cy="16" r="4.5" fill="#2f7d5b"/></svg>
        <div>
            <p class="text-white font-extrabold text-[15px] leading-tight tracking-tight">SecureVault</p>
            <p class="text-white/40 text-[11px] font-semibold uppercase tracking-wider">Administration</p>
        </div>
    </div>

    <nav class="flex-1 px-3 py-5 overflow-y-auto space-y-6">

        <div>
            <p class="text-[10px] font-bold text-white/30 uppercase tracking-widest px-3 mb-2">Vue générale</p>

            {%- set _is = (_route == 'admin_dashboard') -%}
            <a href="{{ path('admin_dashboard') }}" class="{{ _li }} {{ _is ? _active : _inactive }}">
                <svg class="w-[18px] h-[18px] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                <span>Tableau de bord</span>
            </a>
        </div>

        <div>
            <p class="text-[10px] font-bold text-white/30 uppercase tracking-widest px-3 mb-2">Gestion</p>

            {%- set _is = (_route starts with 'admin_users') -%}
            <a href="{{ path('admin_users') }}" class="{{ _li }} {{ _is ? _active : _inactive }}">
                <svg class="w-[18px] h-[18px] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                <span>Utilisateurs</span>
            </a>

            {%- set _is = (_route starts with 'admin_contacts') -%}
            <a href="{{ path('admin_contacts') }}" class="{{ _li }} {{ _is ? _active : _inactive }}">
                <svg class="w-[18px] h-[18px] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <span>Messages de contact</span>
                {% if unread_count is defined and unread_count > 0 %}
                    <span class="ml-auto bg-accent text-brand text-[10px] font-extrabold min-w-[20px] h-5 px-1.5 rounded-full flex items-center justify-center">{{ unread_count > 9 ? '9+' : unread_count }}</span>
                {% endif %}
            </a>
        </div>

        <div>
            <p class="text-[10px] font-bold text-white/30 uppercase tracking-widest px-3 mb-2">Navigation</p>

            <a href="{{ path('app_dashboard') }}" class="{{ _li }} {{ _inactive }}">
                <svg class="w-[18px] h-[18px] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                <span>Retour à l'app</span>
            </a>
        </div>
    </nav>

    <div class="border-t border-white/[.08] p-3">
        <div class="flex items-center gap-3 px-2 py-2.5 rounded-xl">
            <div class="h-9 w-9 rounded-full bg-accent flex items-center justify-center text-brand text-[12px] font-extrabold flex-shrink-0">
                {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-white text-[13.5px] font-bold leading-tight truncate">{{ app.user.firstName }} {{ app.user.lastName }}</p>
                <p class="text-white/40 text-[11px]">Administrateur</p>
            </div>
        </div>
        <a href="{{ path('app_logout') }}" class="flex items-center gap-2.5 w-full px-3 py-2 rounded-xl text-white/50 hover:text-white hover:bg-white/[.06] transition mt-1">
            <svg class="w-[18px] h-[18px] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            <span class="text-[13.5px] font-semibold">Déconnexion</span>
        </a>
    </div>
</aside>

{# Mobile overlay #}
<div id="svOverlay" onclick="document.getElementById('svSidebar').classList.add('-translate-x-full');this.classList.add('hidden')" class="fixed inset-0 bg-brand/40 backdrop-blur-sm z-50 hidden lg:hidden"></div>

{# ── Main column ── #}
<div class="flex-1 lg:ml-64 flex flex-col min-h-screen min-w-0">

    <header class="h-16 bg-canvas/90 backdrop-blur border-b border-line flex items-center gap-3 px-4 lg:px-6 sticky top-0 z-40">
        <button onclick="document.getElementById('svSidebar').classList.toggle('-translate-x-full');document.getElementById('svOverlay').classList.toggle('hidden')"
            class="lg:hidden p-2 -ml-2 text-ink-soft hover:text-ink rounded-xl hover:bg-white transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div class="flex-1">
            <p class="text-[13px] font-bold text-ink-muted uppercase tracking-widest">{% block page_label %}Admin{% endblock %}</p>
        </div>
        <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2 text-[13px] font-semibold text-ink-muted hover:text-ink border border-line bg-white px-3 py-2 rounded-full transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            <span class="hidden sm:inline">Retour à l'app</span>
        </a>
    </header>

    <main class="flex-1 p-6 lg:p-8">
        {% block content %}{% endblock %}
    </main>
</div>

{% block javascripts %}{% endblock %}
</body>
</html>
